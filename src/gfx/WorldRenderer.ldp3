import System.Collections.ArrayList;
import Agents.World.Grid;
import Agents.World.Biome;
import Agents.World.Camera;
import Agents.World.ResourceNode;
import Agents.World.ResourceKind;
import Agents.Gfx.Batch2D;
import Agents.Gfx.Atlas;

// Draws the world from the original's real pixel art (the sprite atlas): each terrain cell is one of its
// biome's five 64x32 diamond variants, drawn back-to-front (by gx+gy) so the tiles composite seamlessly,
// and each resource node is its prop sprite standing on its cell. Off-screen cells are culled. The batch
// must have the atlas texture bound (begin(..., atlasTex)).
program AgentsExe;

public bundle Agents {
    public namespace Gfx {

        public class WorldRenderer {

            // The atlas lays each biome's tile variants out contiguously (ordinal*5 + variant); the biome
            // already knows its own ascending-elevation ordinal, so ask it rather than re-deriving one.
            private static method biomeId(Biome b, int variant) returns int {
                return b.id() * 5 + variant;
            }

            private static method propId(ResourceKind k) returns int {
                switch (k) {
                    case ResourceKind.Bush {
                        return 33;
                    }
                    case ResourceKind.StoneNode {
                        return 34;
                    }
                    case ResourceKind.IronNode {
                        return 35;
                    }
                    case ResourceKind.Fauna {
                        return 60;
                    }
                    default {
                        return 30;
                    }
                }
            }

            public static method draw(Batch2D* batch, Grid* g, Camera* cam, Atlas* atlas) returns void {
                int w = g.width;
                int h = g.height;
                int sw = cam.screenW;
                int sh = cam.screenH;
                mutable int hw = cast<int>(cam.halfW());
                mutable int hh = cast<int>(cam.halfH);
                if (hw < 1) {
                    hw = 1;
                }
                if (hh < 1) {
                    hh = 1;
                }
                int last = w + h - 2;
                mutable int s = 0;
                while (s <= last) {
                    mutable int gx = 0;
                    if (s - (h - 1) > 0) {
                        gx = s - (h - 1);
                    }
                    mutable int gxEnd = s;
                    if (gxEnd > w - 1) {
                        gxEnd = w - 1;
                    }
                    while (gx <= gxEnd) {
                        int gy = s - gx;
                        mutable Biome bm = g.biomeAt(gx, gy);
                        int elev = bm.elevation();
                        int sx = cam.screenX(gx, gy);
                        int sy = cam.screenY(gx, gy, elev);
                        if (!(sx + hw < 0 || sx - hw > sw || sy - hh > sh + elev * hh || sy + hh < 0)) {
                            // Mountain/Snow tiles rise; draw their cliff side-faces down to the ground so the
                            // plateau reads as raised, not floating (isometric z-stacking).
                            if (elev > 0) {
                                int d = elev * hh;
                                float br = cast<float>(bm.red()) / 255.0;
                                float bg = cast<float>(bm.green()) / 255.0;
                                float bb = cast<float>(bm.blue()) / 255.0;
                                batch.quad(sx - hw, sy, sx, sy + hh, sx, sy + hh + d, sx - hw, sy + d,
                                           br * 0.5, bg * 0.5, bb * 0.5, 1.0);
                                batch.quad(sx, sy + hh, sx + hw, sy, sx + hw, sy + d, sx, sy + hh + d,
                                           br * 0.66, bg * 0.66, bb * 0.66, 1.0);
                            }
                            long hv = (cast<long>(gx) * 73856093 ^ cast<long>(gy) * 19349663)
                                      & 9223372036854775807;
                            int variant = cast<int>(hv % 5);
                            int id = WorldRenderer.biomeId(bm, variant);
                            batch.sprite(sx - hw, sy - hh, hw * 2, hh * 2, atlas.u0[id], atlas.v0[id],
                                         atlas.u1[id], atlas.v1[id], 1.0);
                        }
                        gx = gx + 1;
                    }
                    s = s + 1;
                }
            }

            public static method drawResources(Batch2D* batch, Grid* g, ArrayList<ResourceNode*>* nodes,
                                               Camera* cam, Atlas* atlas) returns void {
                int sw = cam.screenW;
                int sh = cam.screenH;
                float scale = cast<float>(cast<int>(cam.halfW())) / 32.0;
                mutable int i = 0;
                while (i < nodes.size()) {
                    mutable ResourceNode* n = nodes.get(i);
                    if (n.alive) {
                        int id = WorldRenderer.propId(n.kind);
                        int dw = cast<int>(cast<float>(atlas.pw[id]) * scale);
                        int dh = cast<int>(cast<float>(atlas.ph[id]) * scale);
                        int sx = cam.projX(cast<float>(n.gx) + 0.5, cast<float>(n.gy) + 0.5);
                        int sy = cam.projY(cast<float>(n.gx) + 0.5, cast<float>(n.gy) + 0.5, 0);
                        int x = sx - dw / 2;
                        int y = sy - dh;
                        if (!(x + dw < 0 || x > sw || y + dh < 0 || y > sh)) {
                            batch.sprite(x, y, dw, dh, atlas.u0[id], atlas.v0[id], atlas.u1[id],
                                         atlas.v1[id], 1.0);
                        }
                    }
                    i = i + 1;
                }
            }
        }
    }
}

import System.Collections.ArrayList;
import Agents.World.Grid;
import Agents.World.Biome;
import Agents.World.Camera;
import Agents.Sim.Realm;
import Agents.People.Nation;
import Agents.People.Worker;
import Agents.Gfx.Batch2D;

// Draws the inhabitants over the world: each nation's capital as a banner-coloured marker, and every
// living worker as a small upright nation-tinted figure at its projected isometric position, with a
// shadow, a pale head, a facing hint and a carry marker.
program AgentsExe;

public bundle Agents {
    public namespace Gfx {

        public class AgentRenderer {

            public static method draw(Batch2D* batch, Realm* realm, Camera* cam) returns void {
                int sw = cam.screenW;
                int sh = cam.screenH;
                mutable int hh = cast<int>(cam.halfH);
                if (hh < 1) {
                    hh = 1;
                }
                // Capitals: a taller banner marker so each nation's seat stands out.
                mutable int ci = 0;
                while (ci < realm.nations.size()) {
                    mutable Nation* n = realm.nations.get(ci);
                    if (n.alive) {
                        int elev = realm.grid.biomeAt(n.capX, n.capY).elevation();
                        int sx = cam.screenX(n.capX, n.capY);
                        int sy = cam.screenY(n.capX, n.capY, elev);
                        int m = hh + 2;
                        float rf = cast<float>(n.cr) / 255.0;
                        float gf = cast<float>(n.cg) / 255.0;
                        float bf = cast<float>(n.cb) / 255.0;
                        // a pole with a banner diamond on top
                        batch.rect(sx - 1, sy - m * 3, 2, m * 3, 0.15, 0.12, 0.1, 1.0);
                        batch.quad(sx, sy - m * 3 - m, sx + m, sy - m * 3, sx, sy - m * 3 + m,
                                   sx - m, sy - m * 3, rf, gf, bf, 1.0);
                    }
                    ci = ci + 1;
                }
                // Workers: small upright nation-tinted figures at their projected foot position, with a
                // shadow, a pale head, a facing hint and a carry marker.
                mutable int bw = (hh * 3) / 5;
                if (bw < 2) {
                    bw = 2;
                }
                mutable int bh = (hh * 5) / 4;
                if (bh < 3) {
                    bh = 3;
                }
                mutable int hs = (bw * 3) / 4;
                if (hs < 2) {
                    hs = 2;
                }
                mutable int wi = 0;
                while (wi < realm.workers.size()) {
                    mutable Worker* wk = realm.workers.get(wi);
                    if (wk.alive) {
                        int cx = cast<int>(wk.px);
                        int cy = cast<int>(wk.py);
                        int elev = realm.grid.biomeAt(cx, cy).elevation();
                        int fx = cam.projX(wk.px, wk.py);
                        int fy = cam.projY(wk.px, wk.py, elev);
                        int top = fy - bh - hs;
                        if (!(fx + bw < 0 || fx - bw > sw || top > sh || fy < 0)) {
                            mutable Nation* nn = realm.nations.get(wk.nationId);
                            float rf = cast<float>(nn.cr) / 255.0;
                            float gf = cast<float>(nn.cg) / 255.0;
                            float bf = cast<float>(nn.cb) / 255.0;
                            // shadow
                            batch.quad(fx, fy - bw / 3, fx + bw, fy, fx, fy + bw / 3, fx - bw, fy,
                                       0.0, 0.0, 0.0, 0.35);
                            // body
                            batch.rect(fx - bw / 2, fy - bh, bw, bh, rf, gf, bf, 1.0);
                            // head
                            batch.rect(fx - hs / 2, fy - bh - hs, hs, hs, 0.86, 0.76, 0.66, 1.0);
                            // facing hint: a darker pip on the side the worker faces
                            mutable int fpx = fx + hs / 4;
                            if (wk.dir == 2 || wk.dir == 3) {
                                fpx = fx - hs / 4 - 1;
                            }
                            batch.rect(fpx, fy - bh - hs + hs / 4, 1, 1, 0.1, 0.08, 0.06, 1.0);
                            // carry marker (a bundle above the head)
                            if (wk.carryRes >= 0) {
                                batch.rect(fx - 1, top - 2, 3, 3, 0.62, 0.45, 0.22, 1.0);
                            }
                        }
                    }
                    wi = wi + 1;
                }
            }
        }
    }
}

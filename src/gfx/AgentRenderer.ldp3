import System.Collections.ArrayList;
import Agents.World.Camera;
import Agents.Sim.Realm;
import Agents.People.Nation;
import Agents.People.Worker;
import Agents.People.Profession;
import Agents.Gfx.Batch2D;
import Agents.Gfx.Atlas;

// Draws every living worker from the original's 4-direction character sprites -- soldiers as the soldier
// sprite, everyone else as the civilian -- facing its movement direction, standing (bottom-centre pivot)
// on its projected isometric cell.
program AgentsExe;

public bundle Agents {
    public namespace Gfx {

        public class AgentRenderer {

            // Sprite id of a worker: soldiers/generals use the soldier sprite (54+dir), the rest civilian
            // (50+dir). dir order matches the Direction enum: 0 NE, 1 SE, 2 SW, 3 NW.
            private static method charId(Profession prof, int dir) returns int {
                mutable int d = dir;
                if (d < 0 || d > 3) {
                    d = 1;
                }
                if (prof.isSoldier()) {
                    return 54 + d;
                }
                return 50 + d;
            }

            public static method draw(Batch2D* batch, Realm* realm, Camera* cam, Atlas* atlas) returns void {
                int sw = cam.screenW;
                int sh = cam.screenH;
                float scale = cast<float>(cast<int>(cam.halfW())) / 32.0;
                mutable int wi = 0;
                while (wi < realm.workers.size()) {
                    mutable Worker* wk = realm.workers.get(wi);
                    if (wk.alive) {
                        int id = AgentRenderer.charId(wk.profession, wk.dir);
                        int dw = cast<int>(cast<float>(atlas.pw[id]) * scale);
                        int dh = cast<int>(cast<float>(atlas.ph[id]) * scale);
                        int sx = cam.projX(wk.px, wk.py);
                        int sy = cam.projY(wk.px, wk.py, 0);
                        int x = sx - dw / 2;
                        int y = sy - dh;
                        if (!(x + dw < 0 || x > sw || y + dh < 0 || y > sh)) {
                            mutable Nation* n = realm.nations.get(wk.nationId);
                            // Tint the character with its nation's banner colour (kept bright so the
                            // team colour reads at a glance), then a soldier gets a red weapon dot.
                            float cr = 0.35 + 0.65 * cast<float>(n.cr) / 255.0;
                            float cg = 0.35 + 0.65 * cast<float>(n.cg) / 255.0;
                            float cb = 0.35 + 0.65 * cast<float>(n.cb) / 255.0;
                            batch.spriteTinted(x, y, dw, dh, atlas.u0[id], atlas.v0[id], atlas.u1[id],
                                               atlas.v1[id], cr, cg, cb, 1.0);
                        }
                    }
                    wi = wi + 1;
                }
            }
        }
    }
}

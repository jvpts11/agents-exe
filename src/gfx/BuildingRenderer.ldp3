import System.Collections.ArrayList;
import Agents.World.Camera;
import Agents.Sim.Realm;
import Agents.People.Nation;
import Agents.Economy.Building;
import Agents.Economy.BuildingType;
import Agents.Gfx.Batch2D;
import Agents.Gfx.Atlas;

// Draws each nation's buildings from the original's building sprites, standing on their footprint's
// centre cell (bottom-centre pivot). A blueprint under construction draws faintly. Sized by the sprite's
// own pixel dimensions scaled to the tile size, so the art keeps its proportions.
program AgentsExe;

public bundle Agents {
    public namespace Gfx {

        public class BuildingRenderer {

            // Sprite id of a building type (building ids are 40 + the type's ordinal).
            private static method buildId(BuildingType t) returns int {
                if (t == BuildingType.Castle) {
                    return 40;
                }
                if (t == BuildingType.TownHall) {
                    return 41;
                }
                if (t == BuildingType.Farm) {
                    return 42;
                }
                if (t == BuildingType.HuntersLodge) {
                    return 43;
                }
                if (t == BuildingType.Sawmill) {
                    return 44;
                }
                if (t == BuildingType.House) {
                    return 45;
                }
                if (t == BuildingType.HouseMedium) {
                    return 46;
                }
                if (t == BuildingType.HouseLarge) {
                    return 47;
                }
                if (t == BuildingType.Barracks) {
                    return 48;
                }
                // Buildings the sprite atlas has no dedicated art for yet reuse a thematically close one.
                if (t == BuildingType.FishingHut) {
                    return 43;   // like the hunter's lodge
                }
                if (t == BuildingType.Smithy) {
                    return 44;   // like the sawmill
                }
                if (t == BuildingType.Bakery) {
                    return 45;   // like a house
                }
                if (t == BuildingType.Brewery) {
                    return 46;   // like a medium house
                }
                if (t == BuildingType.Forge) {
                    return 48;   // like the barracks (military-industrial)
                }
                return 41;       // Marketplace -> like the town hall (civic)
            }

            public static method draw(Batch2D* batch, Realm* realm, Camera* cam, Atlas* atlas) returns void {
                int sw = cam.screenW;
                int sh = cam.screenH;
                float scale = cast<float>(cast<int>(cam.halfW())) / 32.0;
                mutable int ni = 0;
                while (ni < realm.nations.size()) {
                    mutable Nation* n = realm.nations.get(ni);
                    mutable int bi = 0;
                    while (bi < n.buildings.size()) {
                        mutable Building* b = n.buildings.get(bi);
                        int id = BuildingRenderer.buildId(b.type);
                        int dw = cast<int>(cast<float>(atlas.pw[id]) * scale);
                        int dh = cast<int>(cast<float>(atlas.ph[id]) * scale);
                        float fh = cast<float>(b.type.footprint()) * 0.5 - 0.5;
                        int sx = cam.projX(cast<float>(b.gx) + fh, cast<float>(b.gy) + fh);
                        int sy = cam.projY(cast<float>(b.gx) + fh, cast<float>(b.gy) + fh, 0);
                        int x = sx - dw / 2;
                        int y = sy - dh;
                        if (!(x + dw < 0 || x > sw || y + dh < 0 || y > sh)) {
                            mutable float a = 1.0;
                            if (!b.built) {
                                a = 0.45;
                            }
                            batch.sprite(x, y, dw, dh, atlas.u0[id], atlas.v0[id], atlas.u1[id],
                                         atlas.v1[id], a);
                        }
                        bi = bi + 1;
                    }
                    ni = ni + 1;
                }
            }
        }
    }
}

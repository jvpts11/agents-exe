// The one drawing primitive the scene needs: a filled rectangle in 0-255 RGB. Implemented once on the
// CPU (SoftPainter) and once on the GPU (GlPainter), so a single Scene.paint draws the whole game for
// both the windowed and the headless/verification paths. Exercises interfaces + dynamic dispatch.
program AgentsExe;

public bundle Agents {
    public namespace Gfx {

        public interface Painter {
            method fillRect(int x, int y, int w, int h, int r, int g, int b) returns void;
        }
    }
}

import opengl.glfw.GlWindow;
import opengl.gl.Gl;
import opengl.gl.Wgl;
import System.IO.Console;
import System.IO.File;
import System.Text.StringBuilder;
import Agents.Sim.Realm;
import Agents.World.Grid;
import Agents.People.Nation;
import Agents.People.Worker;
import Agents.Economy.Building;

// The graphical front end: opens a window through ldp3-opengl and paints the live world as coloured
// tiles, with each nation's buildings and people over it, plus a HUD strip. It advances the same Realm
// simulation and draws it every frame. `shot` renders one frame and dumps it to a PPM for verification.
program AgentsExe;

public bundle Agents {
    public namespace Gfx {

        public class Game {
            public static method tile() returns int {
                return 9;
            }

            // Paint one full frame of the world into the batch (already begun).
            public static method draw(Batch2D* batch, Realm* world) returns void {
                mutable Grid* grid = world.grid;
                int ts = Game.tile();
                int gw = grid.width;
                int gh = grid.height;
                // Terrain tiles.
                mutable int y = 0;
                while (y < gh) {
                    mutable int x = 0;
                    while (x < gw) {
                        Game.tileColor(batch, x * ts, y * ts, ts, grid.biomeAt(x, y));
                        x = x + 1;
                    }
                    y = y + 1;
                }
                // Nations: buildings, then people on top.
                mutable int ni = 0;
                while (ni < world.nations.size()) {
                    mutable Nation* n = world.nations.get(ni);
                    if (n.alive) {
                        mutable int bi = 0;
                        while (bi < n.buildings.size()) {
                            mutable Building* b = n.buildings.get(bi);
                            Game.buildingRect(batch, b.x * ts, b.y * ts, ts, b.kind, b.built, n.id);
                            bi = bi + 1;
                        }
                        mutable int mi = 0;
                        while (mi < n.members.size()) {
                            mutable Worker* w = n.members.get(mi);
                            if (w.alive) {
                                Game.personDot(batch, w.x * ts, w.y * ts, ts, n.id, w.isSoldier());
                            }
                            mi = mi + 1;
                        }
                    }
                    ni = ni + 1;
                }
                // HUD strip: a coloured bar per nation showing population and soldiers.
                int hudY = gh * ts + 6;
                Game.hud(batch, world, hudY, gw * ts);
            }

            private static method tileColor(Batch2D* batch, int px, int py, int ts, int biome) returns void {
                if (biome == 0) {
                    batch.rect(px, py, ts, ts, 0.13, 0.32, 0.60, 1.0);
                } else if (biome == 1) {
                    batch.rect(px, py, ts, ts, 0.83, 0.76, 0.52, 1.0);
                } else if (biome == 2) {
                    batch.rect(px, py, ts, ts, 0.33, 0.58, 0.29, 1.0);
                } else if (biome == 3) {
                    batch.rect(px, py, ts, ts, 0.44, 0.41, 0.39, 1.0);
                } else {
                    batch.rect(px, py, ts, ts, 0.92, 0.94, 0.97, 1.0);
                }
            }

            private static method buildingRect(Batch2D* batch, int px, int py, int ts, int kind,
                                                boolean built, int nation) returns void {
                // A nation-tinted border, then the building's own colour inside.
                Game.nationFill(batch, px, py, ts, ts, nation, 1.0);
                int m = 2;
                mutable float r = 0.55;
                mutable float g = 0.40;
                mutable float b = 0.25;
                if (kind == 0) {
                    r = 0.85;
                    g = 0.78;
                    b = 0.30;
                } else if (kind == 1) {
                    r = 0.55;
                    g = 0.80;
                    b = 0.25;
                } else if (kind == 2) {
                    r = 0.60;
                    g = 0.42;
                    b = 0.22;
                } else if (kind == 3) {
                    r = 0.80;
                    g = 0.70;
                    b = 0.55;
                } else {
                    r = 0.70;
                    g = 0.18;
                    b = 0.18;
                }
                if (!built) {
                    r = 0.30;
                    g = 0.30;
                    b = 0.34;
                }
                batch.rect(px + m, py + m, ts - m * 2, ts - m * 2, r, g, b, 1.0);
            }

            private static method personDot(Batch2D* batch, int px, int py, int ts, int nation,
                                            boolean soldier) returns void {
                int s = 6;
                int off = (ts - s) / 2;
                Game.nationFill(batch, px + off, py + off, s, s, nation, 1.0);
                if (soldier) {
                    batch.rect(px + off + 2, py + off + 2, 2, 2, 0.95, 0.95, 0.95, 1.0);
                }
            }

            private static method nationFill(Batch2D* batch, int px, int py, int w, int h, int nation,
                                             float a) returns void {
                if (nation == 0) {
                    batch.rect(px, py, w, h, 0.86, 0.22, 0.20, a);
                } else if (nation == 1) {
                    batch.rect(px, py, w, h, 0.20, 0.48, 0.86, a);
                } else if (nation == 2) {
                    batch.rect(px, py, w, h, 0.92, 0.76, 0.16, a);
                } else if (nation == 3) {
                    batch.rect(px, py, w, h, 0.58, 0.26, 0.72, a);
                } else if (nation == 4) {
                    batch.rect(px, py, w, h, 0.16, 0.72, 0.62, a);
                } else if (nation == 5) {
                    batch.rect(px, py, w, h, 0.90, 0.52, 0.16, a);
                } else if (nation == 6) {
                    batch.rect(px, py, w, h, 0.86, 0.43, 0.67, a);
                } else {
                    batch.rect(px, py, w, h, 0.58, 0.78, 0.24, a);
                }
            }

            private static method hud(Batch2D* batch, Realm* world, int y, int width) returns void {
                batch.rect(0, y - 6, width, 82, 0.10, 0.11, 0.13, 1.0);
                mutable int i = 0;
                mutable int col = 8;
                while (i < world.nations.size()) {
                    mutable Nation* n = world.nations.get(i);
                    int bx = col;
                    Game.nationFill(batch, bx, y, 14, 14, n.id, 1.0);
                    if (n.alive) {
                        int pop = n.livingCount();
                        int sol = n.soldierCount();
                        // population bar (green) and soldier bar (red), scaled.
                        batch.rect(bx + 20, y, pop * 3, 6, 0.35, 0.72, 0.32, 1.0);
                        batch.rect(bx + 20, y + 9, sol * 6, 6, 0.80, 0.25, 0.25, 1.0);
                        if (n.atWarWithAny()) {
                            batch.rect(bx, y + 18, 14, 5, 0.85, 0.20, 0.20, 1.0);
                        }
                    } else {
                        batch.rect(bx + 20, y, 60, 15, 0.30, 0.30, 0.30, 1.0);
                    }
                    col = col + width / world.nations.size();
                    i = i + 1;
                }
            }

            // Render one frame off the current sim state and save it as a PPM (verification only).
            public static method shot(Realm* world, GlWindow* win, Batch2D* batch, String path) returns void {
                int w = win.width();
                int h = win.height();
                Wgl.glViewport(0, 0, w, h);
                Wgl.glClearColor(0.05, 0.06, 0.08, 1.0);
                Wgl.glClear(0x4000);
                batch.begin(w, h, 0);
                Game.draw(batch, world);
                batch.flush();
                win.swap();
                byte[] px = win.gl.readPixelsRgb(0, 0, w, h);
                Game.writePpm(path, px, w, h);
                delete px;
            }

            public static method writePpm(String path, byte[] px, int w, int h) returns void {
                mutable StringBuilder sb = new StringBuilder() on heap;
                sb.append("P3\n");
                sb.appendInt(w);
                sb.append(" ");
                sb.appendInt(h);
                sb.append("\n255\n");
                mutable int y = h - 1;
                while (y >= 0) {
                    mutable int x = 0;
                    while (x < w) {
                        int i = (y * w + x) * 3;
                        sb.appendInt(cast<int>(px[i]) & 255);
                        sb.append(" ");
                        sb.appendInt(cast<int>(px[i + 1]) & 255);
                        sb.append(" ");
                        sb.appendInt(cast<int>(px[i + 2]) & 255);
                        sb.append(" ");
                        x = x + 1;
                    }
                    sb.append("\n");
                    y = y - 1;
                }
                File.writeAll(path, sb.toString());
                delete sb;
            }
        }
    }
}

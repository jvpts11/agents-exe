import Agents.Gfx.Painter;
import Agents.Sim.Realm;
import Agents.World.Grid;
import Agents.People.Nation;
import Agents.People.Worker;
import Agents.Economy.Building;
import Agents.World.ResourceNode;

// The single scene painter: draws the whole game once, through a Painter, so the CPU and GPU back ends
// share one drawing. Terrain gets per-cell shading so it is not flat; buildings are little pixel icons
// (a nation-tinted base + a darker roof); people are dots, soldiers pipped, generals larger.
program AgentsExe;

public bundle Agents {
    public namespace Gfx {

        public class Scene {
            public static method tile() returns int {
                return 9;
            }

            public static method canvasW(Realm* world) returns int {
                return world.grid.width * Scene.tile();
            }
            public static method canvasH(Realm* world) returns int {
                return world.grid.height * Scene.tile() + 82;
            }

            public static method paint(Painter* p, Realm* world) returns void {
                mutable Grid* grid = world.grid;
                int ts = Scene.tile();
                int gw = grid.width;
                int gh = grid.height;
                p.fillRect(0, 0, gw * ts, gh * ts + 82, 13, 15, 20);
                mutable int y = 0;
                while (y < gh) {
                    mutable int x = 0;
                    while (x < gw) {
                        long hh = cast<long>(x) * 2246822519 + cast<long>(y) * 3266489917
                                  + cast<long>(x) * cast<long>(y) * 40503;
                        int sh = cast<int>((hh / 131072) % 9) - 4;   // scattered -4..4, not a grid
                        Scene.biome(p, x * ts, y * ts, ts, grid.biomeAt(x, y), sh * 2);
                        x = x + 1;
                    }
                    y = y + 1;
                }
                // The harvestable world -- forests, rock and ore -- drawn under the settlements so it is
                // clear what the gatherers walk out to reach and where a nation chose to settle.
                mutable int ri = 0;
                while (ri < world.resources.size()) {
                    mutable ResourceNode* rn = world.resources.get(ri);
                    if (rn.alive) {
                        Scene.resource(p, rn.x * ts, rn.y * ts, ts, rn.kind);
                    }
                    ri = ri + 1;
                }
                // Ruins of fallen realms: their works stay on the map, greyed and roofless, a record of
                // the empires that rose and fell here. Drawn first, so the living build over history.
                mutable int di = 0;
                while (di < world.nations.size()) {
                    mutable Nation* dn = world.nations.get(di);
                    if (!dn.alive) {
                        mutable int dbi = 0;
                        while (dbi < dn.buildings.size()) {
                            mutable Building* db = dn.buildings.get(dbi);
                            if (db.built) {
                                Scene.ruin(p, db.x * ts, db.y * ts, ts);
                            }
                            dbi = dbi + 1;
                        }
                    }
                    di = di + 1;
                }
                mutable int ni = 0;
                while (ni < world.nations.size()) {
                    mutable Nation* n = world.nations.get(ni);
                    if (n.alive) {
                        mutable int bi = 0;
                        while (bi < n.buildings.size()) {
                            mutable Building* b = n.buildings.get(bi);
                            Scene.building(p, b.x * ts, b.y * ts, ts, b.kind, b.built, n.id);
                            bi = bi + 1;
                        }
                        mutable int mi = 0;
                        while (mi < n.members.size()) {
                            mutable Worker* w = n.members.get(mi);
                            if (w.alive) {
                                Scene.person(p, w.x * ts, w.y * ts, ts, n.id, w.job);
                            }
                            mi = mi + 1;
                        }
                    }
                    ni = ni + 1;
                }
                Scene.hud(p, world, gh * ts + 6, gw * ts);
            }

            private static method clamp(int v) returns int {
                if (v < 0) {
                    return 0;
                }
                if (v > 255) {
                    return 255;
                }
                return v;
            }

            private static method biome(Painter* p, int px, int py, int ts, int b, int d) returns void {
                mutable int r = 84;
                mutable int g = 148;
                mutable int bl = 74;
                if (b == 0) {
                    r = 33;
                    g = 82;
                    bl = 153;
                } else if (b == 1) {
                    r = 212;
                    g = 194;
                    bl = 133;
                } else if (b == 3) {
                    r = 112;
                    g = 105;
                    bl = 99;
                } else if (b == 4) {
                    r = 235;
                    g = 240;
                    bl = 247;
                }
                p.fillRect(px, py, ts, ts, Scene.clamp(r + d), Scene.clamp(g + d), Scene.clamp(bl + d));
            }

            // A ruin: a broken grey stump where a fallen nation's building stood, no roof, no colour.
            private static method ruin(Painter* p, int px, int py, int ts) returns void {
                p.fillRect(px + 2, py + 3, ts - 4, ts - 5, 92, 88, 84);
                p.fillRect(px + 3, py + 4, ts / 3, ts / 3, 64, 60, 56);
            }

            // A harvestable node: a tree (trunk + canopy), a stone cluster, an iron outcrop, or a
            // green tuft for bush/fauna. Small, so the settlements and people still read on top.
            private static method resource(Painter* p, int px, int py, int ts, int kind) returns void {
                if (kind == 0) {
                    p.fillRect(px + ts / 2 - 1, py + ts / 2, 2, ts / 2 - 1, 92, 62, 38);
                    p.fillRect(px + 2, py + 1, ts - 4, ts / 2 + 1, 40, 104, 44);
                } else if (kind == 1) {
                    p.fillRect(px + 2, py + ts / 2 - 1, ts - 4, ts / 2, 122, 122, 128);
                    p.fillRect(px + 3, py + 2, ts / 2, ts / 2, 152, 152, 158);
                } else if (kind == 2) {
                    p.fillRect(px + 2, py + 2, ts - 4, ts - 4, 78, 74, 82);
                    p.fillRect(px + ts / 2 - 1, py + 3, 2, ts - 6, 156, 100, 72);
                } else {
                    p.fillRect(px + 3, py + 3, ts - 6, ts - 6, 66, 122, 54);
                }
            }

            // A building icon: a nation-tinted base, a body in the building's colour, and a darker roof
            // band across the top so kinds read at a glance. Blueprints are a hollow grey box.
            private static method building(Painter* p, int px, int py, int ts, int kind, boolean built, int id) returns void {
                Scene.nation(p, px, py, ts, ts, id);
                if (!built) {
                    p.fillRect(px + 2, py + 2, ts - 4, ts - 4, 60, 62, 70);
                    return;
                }
                mutable int r = 150;
                mutable int g = 110;
                mutable int b = 66;
                if (kind == 0) {
                    r = 200;
                    g = 186;
                    b = 96;
                } else if (kind == 6) {
                    r = 176;
                    g = 176;
                    b = 190;
                } else if (kind == 1) {
                    r = 140;
                    g = 204;
                    b = 64;
                } else if (kind == 2) {
                    r = 150;
                    g = 104;
                    b = 54;
                } else if (kind == 3 || kind == 7 || kind == 8) {
                    r = 206;
                    g = 178;
                    b = 138;
                } else if (kind == 4) {
                    r = 179;
                    g = 60;
                    b = 60;
                } else if (kind == 5) {
                    r = 96;
                    g = 140;
                    b = 74;
                } else if (kind == 9) {
                    r = 176;
                    g = 118;
                    b = 204;
                } else if (kind == 10) {
                    r = 72;
                    g = 152;
                    b = 182;
                } else if (kind == 11) {
                    r = 122;
                    g = 112;
                    b = 104;
                }
                p.fillRect(px + 2, py + 2, ts - 4, ts - 4, r, g, b);
                p.fillRect(px + 2, py + 2, ts - 4, (ts - 4) / 2, (r * 6) / 10, (g * 6) / 10, (b * 6) / 10);
                // A dark doorway at the base so the block reads as a building, not a coloured tile.
                p.fillRect(px + ts / 2 - 1, py + ts - 4, 2, 2, (r * 3) / 10, (g * 3) / 10, (b * 3) / 10);
            }

            private static method person(Painter* p, int px, int py, int ts, int id, int job) returns void {
                if (job == 12) {
                    // A colony boat: a brown hull with a nation-coloured sail.
                    p.fillRect(px + 1, py + ts / 2, ts - 2, ts / 2 - 1, 92, 62, 40);
                    Scene.nation(p, px + ts / 2 - 1, py + 1, 3, ts / 2, id);
                    return;
                }
                boolean soldier = job == 7 || job == 11;
                mutable int s = 5;
                if (job == 11) {
                    s = 7;
                }
                int off = (ts - s) / 2;
                Scene.nation(p, px + off, py + off, s, s, id);
                if (soldier) {
                    if (job == 11) {
                        p.fillRect(px + off + 2, py + off + 2, 3, 3, 245, 224, 120);
                    } else {
                        p.fillRect(px + off + 1, py + off + 1, 2, 2, 240, 240, 240);
                    }
                }
            }

            private static method nation(Painter* p, int x, int y, int w, int h, int id) returns void {
                if (id == 0) {
                    p.fillRect(x, y, w, h, 219, 56, 51);
                } else if (id == 1) {
                    p.fillRect(x, y, w, h, 51, 122, 219);
                } else if (id == 2) {
                    p.fillRect(x, y, w, h, 235, 194, 41);
                } else if (id == 3) {
                    p.fillRect(x, y, w, h, 148, 66, 184);
                } else if (id == 4) {
                    p.fillRect(x, y, w, h, 41, 184, 158);
                } else if (id == 5) {
                    p.fillRect(x, y, w, h, 230, 133, 41);
                } else if (id == 6) {
                    p.fillRect(x, y, w, h, 219, 110, 171);
                } else {
                    p.fillRect(x, y, w, h, 148, 199, 61);
                }
            }

            private static method hud(Painter* p, Realm* world, int y, int width) returns void {
                p.fillRect(0, y - 6, width, 82, 26, 28, 33);
                mutable int i = 0;
                mutable int col = 8;
                int stride = width / world.nations.size();
                while (i < world.nations.size()) {
                    mutable Nation* n = world.nations.get(i);
                    Scene.nation(p, col, y, 14, 14, n.id);
                    if (n.alive) {
                        p.fillRect(col + 20, y, n.livingCount() * 2, 6, 89, 184, 82);
                        p.fillRect(col + 20, y + 9, n.soldierCount() * 4, 6, 204, 64, 64);
                        if (n.atWarWithAny()) {
                            p.fillRect(col + 16, y, 3, 14, 217, 51, 51);
                        }
                        // Era pips: one gold square per age reached.
                        mutable int e = 0;
                        while (e <= n.era) {
                            p.fillRect(col + e * 5, y + 18, 4, 4, 245, 214, 90);
                            e = e + 1;
                        }
                    } else {
                        p.fillRect(col + 20, y, 60, 15, 60, 60, 60);
                    }
                    col = col + stride;
                    i = i + 1;
                }
            }
        }
    }
}

import Agents.Gfx.Painter;

// The GPU painter: forwards each filled rectangle to the Batch2D quad batcher, converting 0-255 RGB
// to the shader's 0-1 floats. The windowed game draws through this; the same Scene.paint feeds it.
program AgentsExe;

public bundle Agents {
    public namespace Gfx {

        public class GlPainter implements Painter {
            private mutable Batch2D* batch;

            public constructor GlPainter(Batch2D* batch) {
                this.batch = batch;
            }

            public override method fillRect(int x, int y, int w, int h, int r, int g, int b) returns void {
                this.batch.rect(x, y, w, h, cast<float>(r) / 255.0, cast<float>(g) / 255.0,
                                cast<float>(b) / 255.0, 1.0);
            }
        }
    }
}

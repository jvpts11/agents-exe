import System.Memory;
import System.IO.Paths;

// Resolves file paths relative to the running executable (via GetModuleFileNameA) instead of hardcoding an
// absolute location, so the game runs from any machine/folder. Assets ship in ../assets next to the build
// output; saves and headless dumps sit beside the exe.
program AgentsExe;

public bundle Agents {
    public namespace App {

        public class AppPaths {
            public extern stdcall static method GetModuleFileNameA(long hModule, long buf, int size) returns int;

            // The directory the executable lives in.
            public static method exeDir() returns String {
                address buf = Memory.alloc(520);
                int n = AppPaths.GetModuleFileNameA(0, cast<long>(buf), 520);
                mutable String full = "";
                if (n > 0) {
                    full = Memory.readString(buf, n);
                }
                Memory.free(buf);
                return Paths.dirname(full);
            }

            // A bundled asset (in ../assets relative to the exe, i.e. the project's assets folder).
            public static method asset(String name) returns String {
                return AppPaths.exeDir() + "/../assets/" + name;
            }

            // A writable file beside the exe (saves, dumps).
            public static method data(String name) returns String {
                return AppPaths.exeDir() + "/" + name;
            }
        }
    }
}

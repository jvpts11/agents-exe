import System.IO.Console;
import System.Collections.ArrayList;
import Agents.World.Grid;
import Agents.World.Biomes;
import Agents.Economy.Building;
import Agents.Economy.Bld;
import Agents.People.Nation;
import Agents.People.Worker;
import Agents.People.Trait;
import Agents.Sim.Realm;

// The terminal renderer. Paints the world overlaid with each nation's people and buildings, then a
// per-nation dashboard and the recent-events feed. Map legend: '~' ocean  '.' beach  ' ' grass
// '^' mountain  '*' snow; digits 1-4 are a nation's people, letters H/F/W/h/B are its
// TownHall/Farm/saWmill/house/Barracks, '?' a blueprint.
program AgentsExe;

public bundle Agents {
    public namespace App {

        public class Renderer {
            public static method frame(Realm* world) returns void {
                mutable Grid* grid = world.grid;
                int w = grid.width;
                int h = grid.height;
                char[] canvas = new char[w * h]();
                mutable int i = 0;
                while (i < w * h) {
                    canvas[i] = Biomes.glyph(grid.biomeAt(i % w, i / w));
                    i = i + 1;
                }
                // People first, then buildings on top.
                mutable int ni = 0;
                while (ni < world.nations.size()) {
                    mutable Nation* n = world.nations.get(ni);
                    if (n.alive) {
                        mutable int mi = 0;
                        while (mi < n.members.size()) {
                            mutable Worker* wk = n.members.get(mi);
                            if (wk.alive && grid.inBounds(wk.x, wk.y)) {
                                canvas[wk.y * w + wk.x] = n.glyph;
                            }
                            mi = mi + 1;
                        }
                        mutable int bi = 0;
                        while (bi < n.buildings.size()) {
                            mutable Building* b = n.buildings.get(bi);
                            if (grid.inBounds(b.x, b.y)) {
                                mutable char g = Bld.glyph(b.kind);
                                if (!b.built) {
                                    g = '?';
                                }
                                canvas[b.y * w + b.x] = g;
                            }
                            bi = bi + 1;
                        }
                    }
                    ni = ni + 1;
                }
                mutable int y = 0;
                while (y < h) {
                    mutable int x = 0;
                    while (x < w) {
                        System.IO.Console.printf("%c", canvas[y * w + x]);
                        x = x + 1;
                    }
                    System.IO.Console.printf("\n");
                    y = y + 1;
                }
                delete canvas;
            }

            public static method dashboard(Realm* world) returns void {
                System.IO.Console.println("");
                System.IO.Console.println($"== tick {world.tick}  year {world.year()}  nations alive: {world.aliveNations()} ==");
                mutable int i = 0;
                while (i < world.nations.size()) {
                    mutable Nation* n = world.nations.get(i);
                    if (n.alive) {
                        String war = n.atWarWithAny() ? "WAR " : "peace";
                        System.IO.Console.println($"  {n.glyph} {n.name} [{Trait.name(n.personality)}] {war} pop={n.livingCount()} sol={n.soldierCount()}/{n.desiredSoldiers} hall={n.townHallHp}");
                        System.IO.Console.println($"      food={n.stock.get(0)} wood={n.stock.get(1)} planks={n.stock.get(2)} stone={n.stock.get(3)} iron={n.stock.get(4)}  builds: F{n.countBuilding(1)} W{n.countBuilding(2)} h{n.countBuilding(3)} B{n.countBuilding(4)}  wins={n.warsWon}");
                        System.IO.Console.println($"      leader intent: {n.lastIntent} -- \"{n.lastReason}\"");
                    } else {
                        System.IO.Console.println($"  {n.glyph} {n.name} -- fallen");
                    }
                    i = i + 1;
                }
                System.IO.Console.println("  -- recent world events --");
                mutable int f = 0;
                while (f < world.intentFeed.size()) {
                    System.IO.Console.println($"    {world.intentFeed.get(f)}");
                    f = f + 1;
                }
            }
        }
    }
}

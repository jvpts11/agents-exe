import System.IO.File;

// Seed-based save/load, faithful to the original's save_v1 model: a game is fully determined by its world
// seed and how far the clock has run, so a slot stores just those two numbers. Loading rebuilds the world
// from the seed and fast-forwards the simulation to the saved tick. Five slots, files in the project root.
program AgentsExe;

public bundle Agents {
    public namespace Shell {

        public class Save {
            private static method path(int slot) returns String {
                return AppPaths.data($"save_slot{slot}.txt");
            }

            public static method write(int seed, int tick, int slot) returns boolean {
                return File.writeAll(Save.path(slot), $"{seed} {tick}");
            }

            public static method exists(int slot) returns boolean {
                return File.exists(Save.path(slot));
            }

            public static method readSeed(int slot) returns int {
                return Save.nthInt(File.readAll(Save.path(slot)), 0);
            }

            public static method readTick(int slot) returns int {
                return Save.nthInt(File.readAll(Save.path(slot)), 1);
            }

            // The `which`-th non-negative integer embedded in `s` (0-based); 0 if absent.
            private static method nthInt(String s, int which) returns int {
                mutable int idx = 0;
                mutable int v = 0;
                mutable boolean inNum = false;
                mutable int i = 0;
                while (i < s.length()) {
                    int c = cast<int>(s.charAt(i));
                    boolean digit = c >= 48 && c <= 57;
                    if (digit) {
                        if (!inNum) {
                            inNum = true;
                            v = 0;
                        }
                        v = v * 10 + (c - 48);
                    } else {
                        if (inNum) {
                            if (idx == which) {
                                return v;
                            }
                            idx = idx + 1;
                            inNum = false;
                        }
                    }
                    i = i + 1;
                }
                if (inNum && idx == which) {
                    return v;
                }
                return 0;
            }
        }
    }
}

// Building ordinals + their construction costs (planks, stone, iron), per-city caps, housing capacity
// and prerequisites. Castle and TownHall are placed for free at founding; the rest are grown from need.
// Mirrors agents.exe's BuildingRegistry/BuildingFootprintCatalog (the nine real buildings).
program AgentsExe;

public bundle Agents {
    public namespace Economy {

        public class Bld {
            public static method townhall() returns int {
                return 0;
            }
            public static method farm() returns int {
                return 1;
            }
            public static method sawmill() returns int {
                return 2;
            }
            public static method house() returns int {
                return 3;
            }
            public static method barracks() returns int {
                return 4;
            }
            public static method lodge() returns int {
                return 5;
            }
            public static method castle() returns int {
                return 6;
            }
            public static method houseMed() returns int {
                return 7;
            }
            public static method houseLarge() returns int {
                return 8;
            }
            public static method count() returns int {
                return 9;
            }
            public static method name(int t) returns String {
                if (t == 0) {
                    return "TownHall";
                }
                if (t == 1) {
                    return "Farm";
                }
                if (t == 2) {
                    return "Sawmill";
                }
                if (t == 3) {
                    return "House";
                }
                if (t == 4) {
                    return "Barracks";
                }
                if (t == 5) {
                    return "HuntersLodge";
                }
                if (t == 6) {
                    return "Castle";
                }
                if (t == 7) {
                    return "HouseMedium";
                }
                return "HouseLarge";
            }
            public static method costPlanks(int t) returns int {
                if (t == 1) {
                    return 8;
                }
                if (t == 2) {
                    return 6;
                }
                if (t == 3) {
                    return 5;
                }
                if (t == 4) {
                    return 10;
                }
                if (t == 5) {
                    return 8;
                }
                if (t == 7) {
                    return 12;
                }
                if (t == 8) {
                    return 25;
                }
                return 0;
            }
            public static method costStone(int t) returns int {
                if (t == 1) {
                    return 4;
                }
                if (t == 2) {
                    return 6;
                }
                if (t == 3) {
                    return 3;
                }
                if (t == 4) {
                    return 8;
                }
                if (t == 5) {
                    return 4;
                }
                if (t == 7) {
                    return 6;
                }
                if (t == 8) {
                    return 12;
                }
                return 0;
            }
            public static method costIron(int t) returns int {
                if (t == 2) {
                    return 3;
                }
                if (t == 4) {
                    return 6;
                }
                if (t == 5) {
                    return 3;
                }
                return 0;
            }
            public static method perCityCap(int t) returns int {
                if (t == 1) {
                    return 6;
                }
                if (t == 2) {
                    return 3;
                }
                if (t == 3) {
                    return 40;
                }
                if (t == 4) {
                    return 2;
                }
                if (t == 5) {
                    return 4;
                }
                if (t == 7) {
                    return 20;
                }
                if (t == 8) {
                    return 12;
                }
                return 1;
            }
            // People a completed house shelters (House 2, Medium 4, Large 8). Non-houses shelter none.
            public static method housing(int t) returns int {
                if (t == 3) {
                    return 2;
                }
                if (t == 7) {
                    return 4;
                }
                if (t == 8) {
                    return 8;
                }
                return 0;
            }
            public static method glyph(int t) returns char {
                if (t == 0) {
                    return 'H';
                }
                if (t == 1) {
                    return 'F';
                }
                if (t == 2) {
                    return 'W';
                }
                if (t == 3) {
                    return 'h';
                }
                if (t == 4) {
                    return 'B';
                }
                if (t == 5) {
                    return 'L';
                }
                if (t == 6) {
                    return 'C';
                }
                if (t == 7) {
                    return 'm';
                }
                return 'M';
            }
        }
    }
}

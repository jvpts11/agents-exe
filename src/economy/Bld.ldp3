// Building ordinals + their construction costs (planks, stone, iron) and per-city caps. The TownHall
// is placed for free at founding; the rest are grown from need.
program AgentsExe;

public bundle Agents {
    public namespace Economy {

        public class Bld {
            public static method townhall() returns int {
                return 0;
            }
            public static method farm() returns int {
                return 1;
            }
            public static method sawmill() returns int {
                return 2;
            }
            public static method house() returns int {
                return 3;
            }
            public static method barracks() returns int {
                return 4;
            }
            public static method count() returns int {
                return 5;
            }
            public static method name(int t) returns String {
                if (t == 0) {
                    return "TownHall";
                }
                if (t == 1) {
                    return "Farm";
                }
                if (t == 2) {
                    return "Sawmill";
                }
                if (t == 3) {
                    return "House";
                }
                return "Barracks";
            }
            public static method costPlanks(int t) returns int {
                if (t == 1) {
                    return 8;
                }
                if (t == 2) {
                    return 6;
                }
                if (t == 3) {
                    return 5;
                }
                if (t == 4) {
                    return 10;
                }
                return 0;
            }
            public static method costStone(int t) returns int {
                if (t == 1) {
                    return 4;
                }
                if (t == 2) {
                    return 6;
                }
                if (t == 3) {
                    return 3;
                }
                if (t == 4) {
                    return 8;
                }
                return 0;
            }
            public static method costIron(int t) returns int {
                if (t == 2) {
                    return 3;
                }
                if (t == 4) {
                    return 6;
                }
                return 0;
            }
            public static method perCityCap(int t) returns int {
                if (t == 1) {
                    return 6;
                }
                if (t == 2) {
                    return 3;
                }
                if (t == 3) {
                    return 99;
                }
                if (t == 4) {
                    return 2;
                }
                return 1;
            }
            public static method glyph(int t) returns char {
                if (t == 0) {
                    return 'H';
                }
                if (t == 1) {
                    return 'F';
                }
                if (t == 2) {
                    return 'W';
                }
                if (t == 3) {
                    return 'h';
                }
                return 'B';
            }
        }
    }
}

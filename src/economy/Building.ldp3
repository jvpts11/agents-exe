// A placed building (or blueprint) at a grid cell: its type, its top-left cell, whether it is finished,
// its current HP, and the builder-time accumulated while it is still a blueprint. A blueprint becomes a
// building once enough construction time is banked.
program AgentsExe;

public bundle Agents {
    public namespace Economy {

        public class Building {
            public mutable BuildingType type;
            public mutable int gx;
            public mutable int gy;
            public mutable boolean built;
            public mutable int hp;
            public mutable float progress;   // seconds of builder-time toward completion

            public constructor Building(BuildingType type, int gx, int gy, boolean built) {
                this.type = type;
                this.gx = gx;
                this.gy = gy;
                this.built = built;
                this.progress = 0.0;
                if (built) {
                    this.hp = type.hp();
                } else {
                    this.hp = 1;
                }
            }

            public method markBuilt() returns void {
                this.built = true;
                this.hp = this.type.hp();
            }
        }
    }
}

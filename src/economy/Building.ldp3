// One structure on the map. Blueprints start unconstructed with 0 progress; a Builder raises progress
// to the build time and calls markBuilt. A TownHall/Barracks can take damage in war.
program AgentsExe;

public bundle Agents {
    public namespace Economy {

        public class Building {
            public mutable int kind;
            public mutable int x;
            public mutable int y;
            public mutable int nationId;
            public mutable int hp;
            public mutable boolean built;
            public mutable int progress;

            public constructor Building(int kind, int x, int y, int nationId) {
                this.kind = kind;
                this.x = x;
                this.y = y;
                this.nationId = nationId;
                this.hp = 100;
                this.built = false;
                this.progress = 0;
            }

            public method markBuilt() returns void {
                this.built = true;
                this.hp = 100;
            }
        }
    }
}

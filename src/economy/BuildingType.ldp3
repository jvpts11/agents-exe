// The buildable building types and their data, faithful to the original's code-as-data registries
// (BuildingRegistry / BuildingFootprintCatalog): construction cost in planks/stone/iron, footprint side
// in tiles, hit points, per-city cap, and how many couples a house shelters. Castle and TownHall are
// free and placed at founding; the rest are grown from need.
program AgentsExe;

public bundle Agents {
    public namespace Economy {

        public enum BuildingType {
            Castle(0, 0, 0, 3, 500, 1, 0),
            TownHall(0, 0, 0, 2, 300, 1, 0),
            Farm(8, 4, 0, 2, 100, 6, 0),
            HuntersLodge(8, 4, 3, 2, 100, 4, 0),
            Sawmill(6, 6, 3, 2, 100, 3, 0),
            House(5, 3, 0, 1, 100, 999, 1),
            HouseMedium(12, 6, 0, 2, 100, 999, 2),
            HouseLarge(25, 12, 0, 3, 100, 999, 4),
            Barracks(10, 8, 6, 3, 200, 2, 0),
            FishingHut(8, 4, 0, 2, 100, 3, 0),
            Smithy(10, 6, 4, 2, 120, 2, 0),
            Bakery(8, 6, 0, 2, 100, 2, 0),
            Brewery(10, 6, 0, 2, 100, 2, 0),
            Forge(14, 8, 8, 3, 150, 1, 0),
            Marketplace(16, 10, 2, 3, 150, 1, 0);

            private final int planks;
            private final int stone;
            private final int iron;
            private final int foot;
            private final int maxHp;
            private final int cap;
            private final int house;

            public constructor BuildingType(int planks, int stone, int iron, int foot, int maxHp,
                                            int cap, int house) {
                this.planks = planks;
                this.stone = stone;
                this.iron = iron;
                this.foot = foot;
                this.maxHp = maxHp;
                this.cap = cap;
                this.house = house;
            }

            public method costPlanks() returns int {
                return this.planks;
            }
            public method costStone() returns int {
                return this.stone;
            }
            public method costIron() returns int {
                return this.iron;
            }
            public method footprint() returns int {
                return this.foot;
            }
            public method hp() returns int {
                return this.maxHp;
            }
            public method perCityCap() returns int {
                return this.cap;
            }
            public method housing() returns int {
                return this.house;
            }

            // Map a prioritised-building id (a BuildingType ordinal chosen by the Mock heuristic) back to
            // the type. Unknown ids fall back to a plain House.
            public static method fromId(int id) returns BuildingType {
                switch (id) {
                    case 2 {
                        return BuildingType.Farm;
                    }
                    case 3 {
                        return BuildingType.HuntersLodge;
                    }
                    case 4 {
                        return BuildingType.Sawmill;
                    }
                    case 6 {
                        return BuildingType.HouseMedium;
                    }
                    case 7 {
                        return BuildingType.HouseLarge;
                    }
                    case 8 {
                        return BuildingType.Barracks;
                    }
                    default {
                        return BuildingType.House;
                    }
                }
            }
        }
    }
}

// A resource stockpile (ResourceStockpile.cs): the six resource types the economy tracks, indexed
// Food 0, Wood 1, Stone 2, Iron 3, Gold 4, Planks 5. In the original a stockpile is per-city; here a
// nation starts with one and cities are layered on later.
program AgentsExe;

public bundle Agents {
    public namespace Economy {

        public class Stockpile {
            private mutable int[] amounts;

            public constructor Stockpile() {
                this.amounts = new int[6]();
            }

            public destructor ~Stockpile() returns void {
                delete this.amounts;
            }

            public method get(int res) returns int {
                if (res < 0 || res >= 6) {
                    return 0;
                }
                return this.amounts[res];
            }

            public method add(int res, int n) returns void {
                if (res >= 0 && res < 6) {
                    this.amounts[res] = this.amounts[res] + n;
                }
            }

            // Spend if affordable; returns whether it went through.
            public method spend(int res, int n) returns boolean {
                if (res < 0 || res >= 6 || this.amounts[res] < n) {
                    return false;
                }
                this.amounts[res] = this.amounts[res] - n;
                return true;
            }
        }
    }
}

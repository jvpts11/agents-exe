// Six integer resource counters with spend semantics: spend fails, leaving the pile untouched, if it
// cannot afford the amount. A nation's whole economy flows through one of these.
program AgentsExe;

public bundle Agents {
    public namespace Economy {

        public class Stockpile {
            private mutable int[] amount;

            public constructor Stockpile() {
                this.amount = new int[6]();
            }

            public destructor ~Stockpile() returns void {
                delete this.amount;
            }

            public method get(int r) returns int {
                return this.amount[r];
            }

            public method add(int r, int n) returns void {
                this.amount[r] = this.amount[r] + n;
            }

            public method spend(int r, int n) returns boolean {
                if (this.amount[r] < n) {
                    return false;
                }
                this.amount[r] = this.amount[r] - n;
                return true;
            }

            // Can this pile pay planks/stone/iron all at once?
            public method canAfford(int planks, int stone, int iron) returns boolean {
                return this.amount[2] >= planks && this.amount[3] >= stone && this.amount[4] >= iron;
            }

            public method payFor(int planks, int stone, int iron) returns boolean {
                if (!this.canAfford(planks, stone, iron)) {
                    return false;
                }
                this.amount[2] = this.amount[2] - planks;
                this.amount[3] = this.amount[3] - stone;
                this.amount[4] = this.amount[4] - iron;
                return true;
            }

            public method total() returns int {
                mutable int t = 0;
                mutable int i = 0;
                while (i < 6) {
                    t = t + this.amount[i];
                    i = i + 1;
                }
                return t;
            }
        }
    }
}

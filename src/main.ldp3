import System.IO.Console;
import opengl.glfw.GlWindow;
import opengl.gl.Gl;
import opengl.gl.Wgl;
import Agents.Sim.Realm;
import Agents.Gfx.Scene;
import Agents.Gfx.Batch2D;
import Agents.Gfx.GlPainter;
import Agents.Gfx.SoftPainter;

// Entry point. Opens a window through ldp3-opengl and runs the live civilisation simulation, painting
// the world every frame through the shared Scene. The first game written in LDP3. Where no GL context
// is available (headless), it software-renders the run to PPM frames instead -- the same picture.
program AgentsExe;

public bundle Agents {
    public namespace App {

        public class Main {
            public static method main(string[] args) returns void {
                System.IO.Console.println("agents.exe -- the first game written in LDP3");
                mutable Realm* world = new Realm(144, 84, 20260722, 7) on heap;
                int w = Scene.canvasW(world);
                int h = Scene.canvasH(world);

                mutable GlWindow* win = new GlWindow() on heap;
                if (win.open("agents.exe", w, h, 4, 6) == 0) {
                    System.IO.Console.println("No GL window available; software-rendering the run to PPM frames.");
                    mutable int tk = 0;
                    while (tk < 900) {
                        world.advance();
                        if (tk == 60 || tk == 450 || tk == 898) {
                            mutable SoftPainter* sp = new SoftPainter(w, h) on heap;
                            Scene.paint(sp, world);
                            sp.save($"C:/Users/jvpts/Desktop/erros_ldp3/soft_{tk}.ppm");
                            delete sp;
                            System.IO.Console.println($"[soft] tick {tk} alive {world.aliveNations()}");
                        }
                        if (world.aliveNations() <= 1) {
                            tk = 900;
                        }
                        tk = tk + 1;
                    }
                    delete win;
                    delete world;
                    return;
                }
                win.setVSync(1);
                mutable Batch2D* batch = new Batch2D(win.gl) on heap;
                mutable GlPainter* glp = new GlPainter(batch) on heap;

                mutable int frame = 0;
                while (win.isOpen()) {
                    win.pump();
                    if (frame % 2 == 0 && world.aliveNations() > 1) {
                        world.advance();
                    }
                    Wgl.glViewport(0, 0, win.width(), win.height());
                    Wgl.glClearColor(0.05, 0.06, 0.08, 1.0);
                    Wgl.glClear(0x4000);
                    batch.begin(win.width(), win.height(), 0);
                    Scene.paint(glp, world);
                    batch.flush();
                    win.swap();
                    frame = frame + 1;
                }

                delete glp;
                delete batch;
                delete win;
                delete world;
                return;
            }
        }
    }
}

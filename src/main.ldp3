import System.IO.Console;
import opengl.glfw.GlWindow;
import opengl.gltex.Texture;
import opengl.gltext.FontAtlas;
import opengl.gltext.GdiFont;
import Agents.Sim.Realm;
import Agents.People.Nation;
import Agents.Gfx.Batch2D;
import Agents.Gfx.Atlas;
import Agents.Ui.Font;
import Agents.Shell.Game;

// Entry point: bootstrap a Realm from a seed, open a GL window, and hand everything to the interactive
// shell (Game) -- a real-time, playable isometric civilisation. A compile-time switch runs a headless
// pass instead that advances the sim and dumps framebuffer snapshots, for offline verification.
program AgentsExe;

public bundle Agents {
    public namespace App {

        public class Main {
            public static method main(string[] args) returns void {
                boolean headless = false;
                int seed = 42;
                System.IO.Console.println("agents.exe -- a generative-agents civilisation, in LDP3");
                mutable Realm* realm = new Realm(480, 480, seed) on heap;
                System.IO.Console.println($"realm: {realm.nations.size()} nations, {realm.workers.size()} workers, {realm.nodes.size()} nodes");
                mutable GlWindow* win = new GlWindow() on heap;
                if (win.open("agents.exe", 1280, 720, 4, 6) == 0) {
                    System.IO.Console.println("No GL window available.");
                    delete win;
                    delete realm;
                    return;
                }
                win.setVSync(1);
                mutable Batch2D* batch = new Batch2D(win.gl) on heap;
                long gpToken = Texture.startup();
                int atlasTex = Texture.load2DRGBA(win.gl,
                    "C:/Users/jvpts/Documents/GitHub/agents-exe/assets/atlas.png");
                mutable Atlas* atlas = new Atlas() on heap;
                mutable FontAtlas* fa = GdiFont.rasterizeAscii("Consolas", 15);
                int fontTex = Texture.upload2DRGBA(win.gl, fa.pixels, fa.atlasW, fa.atlasH);
                mutable Font* font = new Font(fa, fontTex) on heap;
                mutable Game* game = new Game(realm, win, batch, atlas, atlasTex, font, fontTex,
                                              1280, 720, seed) on heap;
                if (headless) {
                    game.beginPlaying();
                    game.advance(9000);
                    Main.reportNations(realm);
                    game.setFocus(240.0, 240.0);
                    game.setZoom(0.68);
                    game.snapshot("C:/Users/jvpts/Desktop/erros_ldp3/world_full.ppm");
                    game.focusCapital(0);
                    game.setZoom(14.0);
                    game.snapshot("C:/Users/jvpts/Desktop/erros_ldp3/world_close.ppm");
                } else {
                    game.runInteractive();
                }
                delete game;   // the game owns the realm and deletes it
                delete font;
                delete fa;
                delete atlas;
                Texture.shutdown(gpToken);
                delete batch;
                delete win;
                return;
            }

            // A snapshot of the strategic state, for the headless verification path.
            private static method reportNations(Realm* realm) returns void {
                mutable int i = 0;
                while (i < realm.nations.size()) {
                    mutable Nation* n = realm.nations.get(i);
                    mutable String state = "alive";
                    if (!n.alive) {
                        state = "conquered";
                    }
                    System.IO.Console.println($"  [{n.id}] {n.name} ({state}) pop={n.livingCount()} sol={n.soldierCount()} bld={n.buildings.size()} gold={n.stock.get(4)} war={n.firstEnemy()} won={n.warsWon} reigns={n.reigns}");
                    i = i + 1;
                }
                System.IO.Console.println("-- chronicle --");
                mutable int c = 0;
                if (realm.intentLog.size() > 16) {
                    c = realm.intentLog.size() - 16;
                }
                while (c < realm.intentLog.size()) {
                    System.IO.Console.println($"  {realm.intentLog.get(c)}");
                    c = c + 1;
                }
            }
        }
    }
}

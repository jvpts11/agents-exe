import System.IO.Console;
import Agents.Sim.Realm;

// Entry point. Builds a world, seats four AI nations, and runs the simulation headless, painting the
// world and dashboard every so often. The first game written in LDP3.
program AgentsExe;

public bundle Agents {
    public namespace App {

        public class Main {
            public static method main(string[] args) returns void {
                System.IO.Console.println("agents.exe -- the first game written in LDP3 (headless civilisation sandbox)");
                System.IO.Console.println("Four AI nations grow, build, and war on a generated island. Their Leaders decide by");
                System.IO.Console.println("a scripted rule cascade -- the same strategy oracle the original game falls back to.");
                mutable Realm* world = new Realm(78, 38, 20260722, 4) on heap;

                int totalTicks = 900;
                int frameEvery = 180;
                mutable int t = 0;
                while (t < totalTicks) {
                    world.advance();
                    if (world.tick % frameEvery == 0) {
                        System.IO.Console.println("");
                        Renderer.frame(world);
                        Renderer.dashboard(world);
                    }
                    if (world.aliveNations() <= 1) {
                        t = totalTicks;
                    }
                    t = t + 1;
                }

                System.IO.Console.println("");
                System.IO.Console.println("=== FINAL STATE ===");
                Renderer.frame(world);
                Renderer.dashboard(world);
                delete world;
                return;
            }
        }
    }
}

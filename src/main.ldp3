import System.IO.Console;
import opengl.glfw.GlWindow;
import opengl.gl.Wgl;

// Entry point for the faithful rebuild of agents.exe -- a generative-agents civilisation sandbox,
// re-implemented 1:1 in LDP3 (see docs/BLUEPRINT.md and docs/reference/). This is the Phase 0 skeleton:
// it opens the 1280x720 window on the plugged-in LDP3-OpenGL back end and clears it to the game's
// Windows-95 desktop blue. The world, agents, economy, nations and UI land in the phases that follow.
program AgentsExe;

public bundle Agents {
    public namespace App {

        public class Main {
            public static method main(string[] args) returns void {
                System.IO.Console.println("agents.exe (LDP3) -- faithful rebuild, Phase 0");
                mutable GlWindow* win = new GlWindow() on heap;
                if (win.open("agents.exe", 1280, 720, 4, 6) == 0) {
                    System.IO.Console.println("No GL window available.");
                    delete win;
                    return;
                }
                win.setVSync(1);
                while (win.isOpen()) {
                    win.pump();
                    Wgl.glViewport(0, 0, win.width(), win.height());
                    Wgl.glClearColor(0.102, 0.227, 0.353, 1.0);   // Win95 desktop blue (26,58,90)
                    Wgl.glClear(0x4000);
                    win.swap();
                }
                delete win;
                return;
            }
        }
    }
}

import System.IO.Console;
import System.IO.File;
import System.Text.StringBuilder;
import opengl.glfw.GlWindow;
import opengl.gl.Wgl;
import Agents.Sim.Realm;
import Agents.People.Nation;
import Agents.World.Camera;
import Agents.Gfx.Batch2D;
import Agents.Gfx.WorldRenderer;
import Agents.Gfx.AgentRenderer;

// Phase 2 harness: bootstrap a Realm (world + resources + nations + workers, seed 42) and render it
// isometrically through LDP3-OpenGL, then read the framebuffer back to PPMs so it can be verified
// headless -- a whole-map view and a close-up on a nation's capital where its people appear.
program AgentsExe;

public bundle Agents {
    public namespace App {

        public class Main {
            public static method main(string[] args) returns void {
                System.IO.Console.println("agents.exe (LDP3) -- Phase 2: nations & agents");
                mutable Realm* realm = new Realm(480, 480, 42) on heap;
                System.IO.Console.println($"realm: {realm.nations.size()} nations, {realm.workers.size()} workers, {realm.nodes.size()} nodes");
                // Advance ~90 simulated seconds so the gatherers walk out, harvest and stock the capital.
                mutable int t = 0;
                while (t < 2700) {
                    realm.tick(0.0333);
                    t = t + 1;
                }
                mutable Nation* n0 = realm.nations.get(0);
                System.IO.Console.println($"{n0.name}: food={n0.stock.get(0)} wood={n0.stock.get(1)} stone={n0.stock.get(2)} iron={n0.stock.get(3)} living={n0.livingCount()}");
                mutable GlWindow* win = new GlWindow() on heap;
                if (win.open("agents.exe", 1280, 720, 4, 6) == 0) {
                    System.IO.Console.println("No GL window available.");
                    delete win;
                    delete realm;
                    return;
                }
                win.setVSync(1);
                mutable Batch2D* batch = new Batch2D(win.gl) on heap;
                Main.renderView(win, batch, realm, 240.0, 240.0, 0.68, "C:/Users/jvpts/Desktop/erros_ldp3/world_full.ppm");
                mutable float cfx = cast<float>(n0.capX);
                mutable float cfy = cast<float>(n0.capY);
                Main.renderView(win, batch, realm, cfx, cfy, 14.0, "C:/Users/jvpts/Desktop/erros_ldp3/world_close.ppm");
                delete batch;
                delete win;
                delete realm;
                return;
            }

            private static method renderView(GlWindow* win, Batch2D* batch, Realm* realm, float fx,
                                             float fy, float halfH, String path) returns void {
                mutable Camera* cam = new Camera(1280, 720, fx, fy, halfH) on heap;
                mutable int f = 0;
                while (f < 3) {
                    win.pump();
                    Wgl.glViewport(0, 0, win.width(), win.height());
                    Wgl.glClearColor(0.102, 0.227, 0.353, 1.0);
                    Wgl.glClear(0x4000);
                    batch.begin(win.width(), win.height(), 0);
                    WorldRenderer.draw(batch, realm.grid, cam);
                    WorldRenderer.drawResources(batch, realm.grid, realm.nodes, cam);
                    AgentRenderer.draw(batch, realm, cam);
                    batch.flush();
                    if (f == 2) {
                        Main.dump(win, 1280, 720, path);
                    }
                    win.swap();
                    f = f + 1;
                }
                delete cam;
                System.IO.Console.println($"wrote {path}");
            }

            private static method dump(GlWindow* win, int w, int h, String path) returns void {
                byte[] px = win.gl.readPixelsRgb(0, 0, w, h);
                mutable StringBuilder sb = new StringBuilder() on heap;
                sb.append("P3\n");
                sb.appendInt(w);
                sb.append(" ");
                sb.appendInt(h);
                sb.append("\n255\n");
                mutable int y = h - 1;
                while (y >= 0) {
                    mutable int x = 0;
                    while (x < w) {
                        int i = (y * w + x) * 3;
                        sb.appendInt(cast<int>(px[i]) & 255);
                        sb.append(" ");
                        sb.appendInt(cast<int>(px[i + 1]) & 255);
                        sb.append(" ");
                        sb.appendInt(cast<int>(px[i + 2]) & 255);
                        sb.append(" ");
                        x = x + 1;
                    }
                    sb.append("\n");
                    y = y - 1;
                }
                File.writeAll(path, sb.toString());
                delete sb;
            }
        }
    }
}

import System.Collections.ArrayList;
import Agents.Gfx.Batch2D;
import Agents.Sim.Realm;
import Agents.People.Nation;
import Agents.Ui.Font;
import Agents.Ui.Win95;

// The Windows-95 HUD, drawn over the world in a single pass with the font texture bound, laid out like
// the original's in-game HUD (HUDController): a top status bar (Year / Tick / Source), and two stacked
// left-hand panels -- "Active Wars" and "Recent Intents" -- that mirror the original's collapsible side
// panels. The clicked entity's inspector is drawn separately on the right (Game.drawInspector). This
// class only reads the realm, so it is pure presentation.
program AgentsExe;

public bundle Agents {
    public namespace Ui {

        public class Hud {
            public static method draw(Batch2D* b, Realm* realm, Font* font, int speed, int sw,
                                      int sh) returns void {
                Hud.topBar(b, realm, font, speed, sw);
                int warsBottom = Hud.warsPanel(b, realm, font);
                Hud.intentsPanel(b, realm, font, warsBottom + 8);
            }

            private static method topBar(Batch2D* b, Realm* realm, Font* font, int speed, int sw) returns void {
                Win95.raised(b, 0, 0, sw, 30);
                font.draw(b, 8, 8, 2, "agents.exe", 0.0, 0.0, 0.4);
                mutable String spd = "Paused";
                if (speed == 1) {
                    spd = "1x";
                } else if (speed == 2) {
                    spd = "2x";
                } else if (speed == 4) {
                    spd = "4x";
                }
                mutable String clock = $"Year {realm.year()}    Tick {realm.tickCount()}    Source: Mock    Speed {spd}";
                font.draw(b, 220, 10, 1, clock, 0.0, 0.0, 0.0);
                int alive = Hud.aliveCount(realm);
                font.draw(b, sw - 210, 10, 1, $"Nations {alive}    Pop {Hud.totalPop(realm)}", 0.0, 0.0, 0.0);
            }

            // The "Active Wars" panel (top-left): one line per active war pair, like the original's
            // Wars panel. Returns the y just below the panel so the intents feed can stack under it.
            private static method warsPanel(Batch2D* b, Realm* realm, Font* font) returns int {
                int x = 8;
                int y = 40;
                int w = 280;
                int lineH = font.glyphH() + 3;
                int bodyH = 6 * lineH;
                int h = 26 + bodyH;
                Win95.raised(b, x, y, w, h);
                Win95.titleBar(b, x + 3, y + 3, w - 6, 18);
                font.draw(b, x + 8, y + 5, 1, "Active Wars", 1.0, 1.0, 1.0);
                Win95.sunken(b, x + 6, y + 24, w - 12, bodyH, 0.96);
                mutable int row = 0;
                mutable int i = 0;
                while (i < realm.nations.size() && row < 6) {
                    mutable Nation* na = realm.nations.get(i);
                    if (na.alive) {
                        mutable int j = i + 1;
                        while (j < realm.nations.size() && row < 6) {
                            mutable Nation* nb = realm.nations.get(j);
                            if (nb.alive && j < na.atWar.length() && na.atWar[j]) {
                                font.draw(b, x + 12, y + 28 + row * lineH, 1,
                                          $"{na.name}  vs  {nb.name}", 0.55, 0.1, 0.0);
                                row = row + 1;
                            }
                            j = j + 1;
                        }
                    }
                    i = i + 1;
                }
                if (row == 0) {
                    font.draw(b, x + 12, y + 28, 1, "(peace -- no active wars)", 0.3, 0.3, 0.3);
                }
                return y + h;
            }

            // The "Recent Intents" feed (left, below the wars panel): the rolling strategic-event log.
            private static method intentsPanel(Batch2D* b, Realm* realm, Font* font, int y) returns void {
                int x = 8;
                int w = 280;
                int h = 240;
                Win95.raised(b, x, y, w, h);
                Win95.titleBar(b, x + 3, y + 3, w - 6, 18);
                font.draw(b, x + 8, y + 5, 1, "Recent Intents", 1.0, 1.0, 1.0);
                Win95.sunken(b, x + 6, y + 24, w - 12, h - 30, 0.96);
                int lineH = font.glyphH() + 2;
                int maxLines = (h - 40) / lineH;
                int total = realm.intentLog.size();
                mutable int start = total - maxLines;
                if (start < 0) {
                    start = 0;
                }
                mutable int li = start;
                mutable int rowi = 0;
                while (li < total) {
                    String s = realm.intentLog.get(li);
                    mutable float rr = 0.1;
                    mutable float gg = 0.1;
                    mutable float bb = 0.1;
                    if (Hud.contains(s, "CONQUERS")) {
                        rr = 0.6;
                        gg = 0.0;
                        bb = 0.0;
                    } else if (Hud.contains(s, "war")) {
                        rr = 0.5;
                        gg = 0.2;
                        bb = 0.0;
                    }
                    font.draw(b, x + 12, y + 30 + rowi * lineH, 1, s, rr, gg, bb);
                    li = li + 1;
                    rowi = rowi + 1;
                }
            }

            private static method aliveCount(Realm* realm) returns int {
                mutable int c = 0;
                mutable int i = 0;
                while (i < realm.nations.size()) {
                    if (realm.nations.get(i).alive) {
                        c = c + 1;
                    }
                    i = i + 1;
                }
                return c;
            }

            private static method totalPop(Realm* realm) returns int {
                mutable int c = 0;
                mutable int i = 0;
                while (i < realm.nations.size()) {
                    c = c + realm.nations.get(i).livingCount();
                    i = i + 1;
                }
                return c;
            }

            // Minimal substring test (the stdlib String may expose contains, but keep the HUD self-reliant).
            private static method contains(String s, String needle) returns boolean {
                int n = s.length();
                int m = needle.length();
                if (m == 0) {
                    return true;
                }
                mutable int i = 0;
                while (i + m <= n) {
                    mutable int j = 0;
                    mutable boolean hit = true;
                    while (j < m && hit) {
                        if (s.charAt(i + j) != needle.charAt(j)) {
                            hit = false;
                        }
                        j = j + 1;
                    }
                    if (hit) {
                        return true;
                    }
                    i = i + 1;
                }
                return false;
            }
        }
    }
}

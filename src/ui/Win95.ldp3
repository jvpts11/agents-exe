import Agents.Gfx.Batch2D;

// The Windows-95 chrome the original wears: a light-gray face with a two-tone raised/sunken bevel, navy
// title bars, and sunken wells for content. Everything is solid rectangles on Batch2D (texFlag 0, so the
// bound texture is ignored) -- which lets the whole HUD share one draw pass with the glyph texture. The
// classic 3D border is a double frame: white/near-black on the outer ring, light-face/dark-gray inside.
program AgentsExe;

public bundle Agents {
    public namespace Ui {

        public class Win95 {
            // Palette (0..1). The canonical 95 greys plus the title navy.
            public static method faceR() returns float {
                return 0.753;   // 192
            }
            public static method line(Batch2D* b, int x, int y, int w, int h, float v) returns void {
                b.rect(x, y, w, h, v, v, v, 1.0);
            }
            public static method fill(Batch2D* b, int x, int y, int w, int h, float v) returns void {
                b.rect(x, y, w, h, v, v, v, 1.0);
            }

            // A raised panel (button/bar face) with the 95 double bevel.
            public static method raised(Batch2D* b, int x, int y, int w, int h) returns void {
                b.rect(x, y, w, h, 0.753, 0.753, 0.753, 1.0);      // face
                Win95.bevel(b, x, y, w, h, true);
            }

            // A sunken well (content area / text field) with the bevel inverted.
            public static method sunken(Batch2D* b, int x, int y, int w, int h, float v) returns void {
                b.rect(x, y, w, h, v, v, v, 1.0);
                Win95.bevel(b, x, y, w, h, false);
            }

            // The two-tone 3D border. raised: white/light top-left, dark/black bottom-right (sunken swaps).
            private static method bevel(Batch2D* b, int x, int y, int w, int h, boolean raised) returns void {
                mutable float o1 = 1.0;      // outer top-left
                mutable float i1 = 0.875;    // inner top-left
                mutable float o2 = 0.0;      // outer bottom-right
                mutable float i2 = 0.5;      // inner bottom-right
                if (!raised) {
                    o1 = 0.0;
                    i1 = 0.5;
                    o2 = 1.0;
                    i2 = 0.875;
                }
                int r = x + w - 1;
                int bt = y + h - 1;
                // outer ring
                Win95.line(b, x, y, w, 1, o1);           // top
                Win95.line(b, x, y, 1, h, o1);           // left
                Win95.line(b, x, bt, w, 1, o2);          // bottom
                Win95.line(b, r, y, 1, h, o2);           // right
                // inner ring (inset 1px)
                Win95.line(b, x + 1, y + 1, w - 2, 1, i1);
                Win95.line(b, x + 1, y + 1, 1, h - 2, i1);
                Win95.line(b, x + 1, bt - 1, w - 2, 1, i2);
                Win95.line(b, r - 1, y + 1, 1, h - 2, i2);
            }

            // A navy title bar strip (draw text over it in white).
            public static method titleBar(Batch2D* b, int x, int y, int w, int h) returns void {
                b.rect(x, y, w, h, 0.0, 0.0, 0.5, 1.0);
            }

            // A coloured swatch with a 1px dark frame -- a nation banner chip.
            public static method chip(Batch2D* b, int x, int y, int w, int h, float r, float g,
                                      float bl) returns void {
                b.rect(x - 1, y - 1, w + 2, h + 2, 0.0, 0.0, 0.0, 1.0);
                b.rect(x, y, w, h, r, g, bl, 1.0);
            }
        }
    }
}

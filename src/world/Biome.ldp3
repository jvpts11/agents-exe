import System.IO.Console;

// The six elevation-band biomes of the world, exactly as the original: a pure function of normalized
// height, ordered by ascending elevation (Biome.cs). There are no climate biomes -- "forest" is a
// resource cluster, not a biome. Each carries its render colour, whether ground units may stand on it,
// and its visual elevation (0 flat, 1 mountain body, 2 snow cap) used for isometric cliff stacking.
program AgentsExe;

public bundle Agents {
    public namespace World {

        public enum Biome {
            DeepOcean(24, 44, 92, false, 0),
            Ocean(33, 82, 153, false, 0),
            Beach(214, 198, 138, true, 0),
            Grassland(86, 150, 76, true, 0),
            Mountain(120, 112, 104, false, 1),
            Snow(236, 240, 247, false, 2);

            private final int cr;
            private final int cg;
            private final int cb;
            private final boolean walk;
            private final int elev;

            public constructor Biome(int cr, int cg, int cb, boolean walk, int elev) {
                this.cr = cr;
                this.cg = cg;
                this.cb = cb;
                this.walk = walk;
                this.elev = elev;
            }

            public method red() returns int {
                return this.cr;
            }
            public method green() returns int {
                return this.cg;
            }
            public method blue() returns int {
                return this.cb;
            }
            // Ground units stand only on Grassland and Beach (PassabilityMap.ForGroundUnits).
            public method walkable() returns boolean {
                return this.walk;
            }
            // Visual elevation for isometric cliff/z-stacking (elevationByBiome = {0,0,0,0,1,2}).
            public method elevation() returns int {
                return this.elev;
            }

            // The world stores biomes as an id-per-tile parallel array (the faithful model); these bridge
            // the flat int grid and the enum. `id` is the ascending-elevation ordinal.
            public method id() returns int {
                if (this == Biome.DeepOcean) {
                    return 0;
                }
                if (this == Biome.Ocean) {
                    return 1;
                }
                if (this == Biome.Beach) {
                    return 2;
                }
                if (this == Biome.Grassland) {
                    return 3;
                }
                if (this == Biome.Mountain) {
                    return 4;
                }
                return 5;
            }

            public static method fromId(int id) returns Biome {
                if (id == 0) {
                    return Biome.DeepOcean;
                }
                if (id == 1) {
                    return Biome.Ocean;
                }
                if (id == 2) {
                    return Biome.Beach;
                }
                if (id == 3) {
                    return Biome.Grassland;
                }
                if (id == 4) {
                    return Biome.Mountain;
                }
                return Biome.Snow;
            }
        }
    }
}

import System.IO.Console;

// A deterministic Park-Miller minimal-standard LCG. The multiply stays inside 2^46, so it never
// overflows a 64-bit long -- no trap, fully reproducible from a seed. Every random choice in the
// world (generation, spawning, decisions) draws from one of these so runs replay identically.
program AgentsExe;

public bundle Agents {
    public namespace World {

        public class Rng {
            private mutable long state;

            public constructor Rng(int seed) {
                mutable long s = cast<long>(seed);
                if (s <= 0) {
                    s = 1;
                }
                this.state = s % 2147483647;
                if (this.state == 0) {
                    this.state = 1;
                }
            }

            public method next() returns int {
                this.state = (this.state * 48271) % 2147483647;
                return cast<int>(this.state);
            }

            // A value in [0, bound).
            public method nextInt(int bound) returns int {
                if (bound <= 0) {
                    return 0;
                }
                return this.next() % bound;
            }

            // A value in [lo, hi].
            public method range(int lo, int hi) returns int {
                if (hi <= lo) {
                    return lo;
                }
                return lo + this.nextInt(hi - lo + 1);
            }

            // Returns true with probability percent/100.
            public method chance(int percent) returns boolean {
                return this.nextInt(100) < percent;
            }

            // A float in [0, 1).
            public method nextFloat() returns float {
                return cast<float>(this.next()) / 2147483647.0;
            }
        }
    }
}

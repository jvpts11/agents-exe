// The harvestable node kinds on the map (ResourceNodeKind.cs): a tree gives Wood, a bush and fauna
// give Food, stone and iron give their ore. Each carries a render colour; the resource it yields and
// its default capacity are decided when a node is created. Fauna is the only mobile kind.
program AgentsExe;

public bundle Agents {
    public namespace World {

        public enum ResourceKind {
            Tree(38, 92, 44),
            Bush(90, 140, 60),
            StoneNode(140, 140, 146),
            IronNode(120, 96, 84),
            Fauna(150, 110, 70);

            private final int cr;
            private final int cg;
            private final int cb;

            public constructor ResourceKind(int cr, int cg, int cb) {
                this.cr = cr;
                this.cg = cg;
                this.cb = cb;
            }

            public method red() returns int {
                return this.cr;
            }
            public method green() returns int {
                return this.cg;
            }
            public method blue() returns int {
                return this.cb;
            }

            // The stockpile resource index a harvested node of this kind yields: Food 0, Wood 1, Stone 2,
            // Iron 3 (bush and fauna both give Food).
            public method yieldIndex() returns int {
                switch (this) {
                    case ResourceKind.StoneNode {
                        return 2;
                    }
                    case ResourceKind.IronNode {
                        return 3;
                    }
                    case ResourceKind.Tree {
                        return 1;
                    }
                    default {
                        return 0;
                    }
                }
            }
        }
    }
}

import System.IO.Console;
import System.Collections.ArrayList;
import Agents.Math.Vec2;

// The biome grid. Cells are row-major (y*width + x). Generation lays down a few continents and
// islands as radial height blobs (their centres kept as Vec2), takes the max contribution per cell,
// and thresholds the [0,1000] height into biomes -- a continent mask with radial falloff, all in
// integers so it stays deterministic without a float noise library.
program AgentsExe;

public bundle Agents {
    public namespace World {

        public class Grid {
            public mutable int width;
            public mutable int height;
            private mutable int[] cell;

            public constructor Grid(int w, int h, int seed) {
                this.width = w;
                this.height = h;
                this.cell = new int[w * h]();
                this.generate(seed);
            }

            public destructor ~Grid() returns void {
                delete this.cell;
            }

            public method index(int x, int y) returns int {
                return y * this.width + x;
            }

            public method inBounds(int x, int y) returns boolean {
                return x >= 0 && y >= 0 && x < this.width && y < this.height;
            }

            public method biomeAt(int x, int y) returns int {
                if (!this.inBounds(x, y)) {
                    return 0;
                }
                return this.cell[this.index(x, y)];
            }

            // Ground units walk only on grassland and beach (agents.exe PassabilityMap.ForGroundUnits).
            public method passable(int x, int y) returns boolean {
                if (!this.inBounds(x, y)) {
                    return false;
                }
                int b = this.cell[this.index(x, y)];
                return b == 1 || b == 2;
            }

            private method generate(int seed) returns void {
                mutable Rng rng = new Rng(seed) on stack;
                int continents = 5;
                int islands = 8;
                int total = continents + islands;
                mutable ArrayList<Vec2*> seeds = new ArrayList<Vec2*>() on heap;
                int[] sr = new int[total]();
                mutable int i = 0;
                while (i < total) {
                    int cx = rng.range(this.width / 10, this.width - this.width / 10);
                    int cy = rng.range(this.height / 10, this.height - this.height / 10);
                    seeds.add(new Vec2(cx, cy) on heap);
                    if (i < continents) {
                        // Medium landmasses set apart, so water channels separate them into an archipelago.
                        sr[i] = rng.range(this.height / 4, (this.height * 2) / 5);
                    } else {
                        sr[i] = rng.range(this.height / 10, this.height / 6);
                    }
                    i = i + 1;
                }
                mutable int y = 0;
                while (y < this.height) {
                    mutable int x = 0;
                    while (x < this.width) {
                        mutable Vec2 here = new Vec2(x, y) on stack;
                        mutable int best = 0;
                        mutable int s = 0;
                        while (s < total) {
                            int distSq = here.dist2(seeds.get(s));
                            int radSq = sr[s] * sr[s];
                            if (radSq > 0 && distSq < radSq) {
                                int contribution = 1000 - (distSq * 1000) / radSq;
                                if (contribution > best) {
                                    best = contribution;
                                }
                            }
                            s = s + 1;
                        }
                        this.cell[this.index(x, y)] = Grid.classify(best);
                        x = x + 1;
                    }
                    y = y + 1;
                }
                mutable int si = 0;
                while (si < seeds.size()) {
                    delete seeds.get(si);
                    si = si + 1;
                }
                delete sr;
            }

            private static method classify(int h) returns int {
                if (h < 210) {
                    return 0;
                }
                if (h < 260) {
                    return 1;
                }
                if (h < 890) {
                    return 2;
                }
                if (h < 960) {
                    return 3;
                }
                return 4;
            }

            // How many walkable cells the world has -- a quick sanity metric.
            public method walkableCount() returns int {
                mutable int n = 0;
                mutable int i = 0;
                int total = this.width * this.height;
                while (i < total) {
                    if (this.cell[i] == 1 || this.cell[i] == 2) {
                        n = n + 1;
                    }
                    i = i + 1;
                }
                return n;
            }
        }
    }
}

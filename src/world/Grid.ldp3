import System.IO.Console;

// The world: the plain 480x480 integer grid that all simulation logic runs on (rendering projects it
// isometrically -- see Iso/WorldRenderer). It generates a heightmap with the original's pipeline
// (domain-warped multi-octave fractal noise + continent/island smoothstep masks + boundary noise,
// then normalized) and collapses it into the six elevation-band biomes. Storage is a flat Biome array
// indexed y*width + x -- faithful to the original's parallel-array model (no per-tile object).
program AgentsExe;

public bundle Agents {
    public namespace World {

        public class Grid {
            public mutable int width;
            public mutable int height;
            public mutable int seed;
            private mutable int[] biome;      // biome id per tile (Biome.id ordinal), a parallel-array grid
            private mutable float[] hmap;

            public constructor Grid(int width, int height, int seed) {
                this.width = width;
                this.height = height;
                this.seed = seed;
                int n = width * height;
                this.biome = new int[n]();
                this.hmap = new float[n]();
                this.generate();
            }

            public destructor ~Grid() returns void {
                delete this.biome;
                delete this.hmap;
            }

            public method inBounds(int x, int y) returns boolean {
                return x >= 0 && y >= 0 && x < this.width && y < this.height;
            }

            public method biomeAt(int x, int y) returns Biome {
                if (!this.inBounds(x, y)) {
                    return Biome.DeepOcean;
                }
                return Biome.fromId(this.biome[y * this.width + x]);
            }

            // The raw biome id at a tile (no enum round-trip) -- the hot path for rendering.
            public method biomeIdAt(int x, int y) returns int {
                if (!this.inBounds(x, y)) {
                    return 0;
                }
                return this.biome[y * this.width + x];
            }

            public method walkable(int x, int y) returns boolean {
                if (!this.inBounds(x, y)) {
                    return false;
                }
                return Biome.fromId(this.biome[y * this.width + x]).walkable();
            }

            // --- generation ---

            private method generate() returns void {
                mutable Rng rng = new Rng(this.seed) on stack;
                int w = this.width;
                int h = this.height;
                // Six large noise offsets, drawn in order (base, warp, boundary), as the original does.
                float ox = rng.nextFloat() * 200000.0 - 100000.0;
                float oy = rng.nextFloat() * 200000.0 - 100000.0;
                float warpOx = rng.nextFloat() * 200000.0 - 100000.0;
                float warpOy = rng.nextFloat() * 200000.0 - 100000.0;
                float boundaryOx = rng.nextFloat() * 200000.0 - 100000.0;
                float boundaryOy = rng.nextFloat() * 200000.0 - 100000.0;

                mutable int minWH = w;
                if (h < w) {
                    minWH = h;
                }
                float minWHd = cast<float>(minWH);
                // 4 continent seeds on a 2x2 normalized grid + 7 island seeds at random positions.
                int total = 11;
                float[] sx = new float[total]();
                float[] sy = new float[total]();
                float[] sr = new float[total]();
                int side = 2;
                float sideD = 2.0;
                mutable int placed = 0;
                mutable int c = 0;
                while (c < 4) {
                    float cxN = (cast<float>(c % side) + 0.5) / sideD;
                    float cyN = (cast<float>(c / side) + 0.5) / sideD;
                    float jx = (rng.nextFloat() * 2.0 - 1.0) * 0.3 / sideD;
                    float jy = (rng.nextFloat() * 2.0 - 1.0) * 0.3 / sideD;
                    sx[placed] = (cxN + jx) * cast<float>(w);
                    sy[placed] = (cyN + jy) * cast<float>(h);
                    sr[placed] = (0.16 + rng.nextFloat() * 0.10) * minWHd;
                    placed = placed + 1;
                    c = c + 1;
                }
                mutable int isl = 0;
                while (isl < 7) {
                    sx[placed] = (0.1 + rng.nextFloat() * 0.8) * cast<float>(w);
                    sy[placed] = (0.1 + rng.nextFloat() * 0.8) * cast<float>(h);
                    sr[placed] = (0.025 + rng.nextFloat() * 0.035) * minWHd;
                    placed = placed + 1;
                    isl = isl + 1;
                }

                // Tectonic plates: a dozen drifting plates over the map. Near a plate boundary, plates
                // converging pile up mountain ranges and diverging plates open ocean trenches; each plate
                // also carries a base elevation (continental vs oceanic). Layered onto the noise heightmap.
                int plates = 12;
                float[] px = new float[plates]();
                float[] py = new float[plates]();
                float[] dvx = new float[plates]();
                float[] dvy = new float[plates]();
                float[] pbase = new float[plates]();
                mutable int p = 0;
                while (p < plates) {
                    px[p] = rng.nextFloat() * cast<float>(w);
                    py[p] = rng.nextFloat() * cast<float>(h);
                    float ax = rng.nextFloat() * 2.0 - 1.0;
                    float ay = rng.nextFloat() * 2.0 - 1.0;
                    mutable float al = Noise.sqrtF(ax * ax + ay * ay);
                    if (al < 0.0001) {
                        al = 1.0;
                    }
                    dvx[p] = ax / al;
                    dvy[p] = ay / al;
                    pbase[p] = rng.nextFloat() * 2.0 - 1.0;
                    p = p + 1;
                }
                float boundW = 0.06 * minWHd;

                mutable float minV = 1000000000.0;
                mutable float maxV = -1000000000.0;
                mutable int y = 0;
                while (y < h) {
                    mutable int x = 0;
                    while (x < w) {
                        float dxf = cast<float>(x);
                        float dyf = cast<float>(y);
                        // Domain warp (3 octaves), scaled and strengthened.
                        float wxn = Noise.fractal((dxf + warpOx) / 110.0, (dyf + warpOy) / 110.0,
                                                   3, 0.5, 2.0) * 18.0;
                        float wyn = Noise.fractal((dxf + warpOx + 5000.0) / 110.0, (dyf + warpOy) / 110.0,
                                                   3, 0.5, 2.0) * 18.0;
                        // Base height (6 octaves) over the warped domain.
                        float base = Noise.fractal((dxf + ox + wxn) / 180.0, (dyf + oy + wyn) / 180.0,
                                                    6, 0.5, 2.0);
                        // Two boundary-noise layers perturb the coastlines.
                        float bnLow = Noise.fractal((dxf + boundaryOx) / 38.0, (dyf + boundaryOy) / 38.0,
                                                     2, 0.6, 2.0) * 0.45;
                        float bnHigh = Noise.fractal((dxf + boundaryOx + 3000.0) / 12.0,
                                                      (dyf + boundaryOy) / 12.0, 2, 0.5, 2.4) * 0.22;
                        float bn = bnLow + bnHigh;
                        mutable float v = base + bn;
                        // Continent/island mask pushes ocean down outside the landmasses.
                        float mask = this.continentMask(x, y, sx, sy, sr, total, bn);
                        v = v - (1.0 - mask) * 0.65;
                        v = v + this.tectonic(x, y, px, py, dvx, dvy, pbase, plates, boundW);
                        this.hmap[y * w + x] = v;
                        if (v < minV) {
                            minV = v;
                        }
                        if (v > maxV) {
                            maxV = v;
                        }
                        x = x + 1;
                    }
                    y = y + 1;
                }

                // Thermal erosion: a few relaxation passes let steep slopes shed material to their lowest
                // neighbour, softening the raw tectonic ridges into more natural mountain flanks.
                mutable int ep = 0;
                while (ep < 3) {
                    mutable int ey = 1;
                    while (ey < h - 1) {
                        mutable int ex = 1;
                        while (ex < w - 1) {
                            int ci = ey * w + ex;
                            float ch = this.hmap[ci];
                            mutable int li = ci;
                            mutable float lh = ch;
                            if (this.hmap[ci - 1] < lh) {
                                lh = this.hmap[ci - 1];
                                li = ci - 1;
                            }
                            if (this.hmap[ci + 1] < lh) {
                                lh = this.hmap[ci + 1];
                                li = ci + 1;
                            }
                            if (this.hmap[ci - w] < lh) {
                                lh = this.hmap[ci - w];
                                li = ci - w;
                            }
                            if (this.hmap[ci + w] < lh) {
                                lh = this.hmap[ci + w];
                                li = ci + w;
                            }
                            float drop = ch - lh;
                            if (drop > 0.03) {
                                float shift = (drop - 0.03) * 0.25;
                                this.hmap[ci] = ch - shift;
                                this.hmap[li] = lh + shift;
                            }
                            ex = ex + 1;
                        }
                        ey = ey + 1;
                    }
                    ep = ep + 1;
                }

                mutable float rangeV = maxV - minV;
                if (rangeV < 0.000001) {
                    rangeV = 1.0;
                }
                float oceanT = 0.42;
                float beachT = 0.46;
                float mountT = 0.62;
                float snowT = 0.78;
                float deepT = oceanT * 0.6;
                int n = w * h;
                mutable int i = 0;
                while (i < n) {
                    float hv = (this.hmap[i] - minV) / rangeV;
                    this.biome[i] = Grid.classify(hv, deepT, oceanT, beachT, mountT, snowT).id();
                    i = i + 1;
                }
                // Rivers: from the high peaks, trace steepest descent to the sea, carving water channels.
                mutable Rng rrng = new Rng(this.seed ^ 4242) on stack;
                mutable int rivers = 0;
                mutable int ry = 2;
                while (ry < h - 2 && rivers < 55) {
                    mutable int rx = 2;
                    while (rx < w - 2 && rivers < 55) {
                        float hn = (this.hmap[ry * w + rx] - minV) / rangeV;
                        if (hn > mountT && rrng.nextFloat() < 0.05) {
                            this.carveRiver(rx, ry, minV, rangeV, oceanT);
                            rivers = rivers + 1;
                        }
                        rx = rx + 6;
                    }
                    ry = ry + 6;
                }
                delete sx;
                delete sy;
                delete sr;
                delete px;
                delete py;
                delete dvx;
                delete dvy;
                delete pbase;
            }

            // Plate-tectonics contribution to elevation at (x,y): find the two nearest plates; near their
            // shared boundary, converging drift (rel>0) raises a mountain range and diverging drift (rel<0)
            // sinks a trench, strongest right at the boundary; plus the owning plate's base elevation.
            private method tectonic(int x, int y, float[] px, float[] py, float[] dvx, float[] dvy,
                                    float[] pbase, int plates, float boundW) returns float {
                float fx = cast<float>(x);
                float fy = cast<float>(y);
                mutable int n1 = 0;
                mutable int n2 = 0;
                mutable float d1 = 1000000000.0;
                mutable float d2 = 1000000000.0;
                mutable int p = 0;
                while (p < plates) {
                    float ddx = fx - px[p];
                    float ddy = fy - py[p];
                    float d = Noise.sqrtF(ddx * ddx + ddy * ddy);
                    if (d < d1) {
                        d2 = d1;
                        n2 = n1;
                        d1 = d;
                        n1 = p;
                    } else if (d < d2) {
                        d2 = d;
                        n2 = p;
                    }
                    p = p + 1;
                }
                float bx = px[n2] - px[n1];
                float by = py[n2] - py[n1];
                mutable float bl = Noise.sqrtF(bx * bx + by * by);
                if (bl < 0.0001) {
                    bl = 1.0;
                }
                float nx = bx / bl;
                float ny = by / bl;
                float rel = (dvx[n1] - dvx[n2]) * nx + (dvy[n1] - dvy[n2]) * ny;
                mutable float ridge = 1.0 - (d2 - d1) / boundW;
                if (ridge < 0.0) {
                    ridge = 0.0;
                }
                return rel * ridge * 0.55 + pbase[n1] * 0.14;
            }

            // Smoothstep continent mask: the max falloff over all seeds; bn perturbs the coastline.
            private method continentMask(int x, int y, float[] sx, float[] sy, float[] sr, int total,
                                         float bn) returns float {
                mutable float best = 0.0;
                mutable int s = 0;
                while (s < total) {
                    float r = sr[s];
                    if (r > 0.0) {
                        float dx = (cast<float>(x) - sx[s]) / r;
                        float dy = (cast<float>(y) - sy[s]) / r;
                        float d = Noise.sqrtF(dx * dx + dy * dy) + bn;
                        if (d < 1.0) {
                            float m = 1.0 - (3.0 * d * d - 2.0 * d * d * d);
                            if (m > best) {
                                best = m;
                            }
                        }
                    }
                    s = s + 1;
                }
                return best;
            }

            // Trace one river from (sx,sy) down the steepest descent, carving each land cell to water
            // until it reaches the sea or a local minimum (which reads as a lake).
            private method carveRiver(int sx, int sy, float minV, float rangeV, float oceanT) returns void {
                int w = this.width;
                int h = this.height;
                int ocean = Biome.Ocean.id();
                int deep = Biome.DeepOcean.id();
                mutable int cx = sx;
                mutable int cy = sy;
                mutable int steps = 0;
                while (steps < 500) {
                    int idx = cy * w + cx;
                    float hn = (this.hmap[idx] - minV) / rangeV;
                    if (hn < oceanT) {
                        return;
                    }
                    if (this.biome[idx] != ocean && this.biome[idx] != deep) {
                        this.biome[idx] = ocean;
                    }
                    mutable int bx = cx;
                    mutable int by = cy;
                    mutable float best = hn;
                    mutable int dy = -1;
                    while (dy <= 1) {
                        mutable int dx = -1;
                        while (dx <= 1) {
                            if (!(dx == 0 && dy == 0)) {
                                int nx = cx + dx;
                                int ny = cy + dy;
                                if (nx >= 0 && ny >= 0 && nx < w && ny < h) {
                                    float nh = (this.hmap[ny * w + nx] - minV) / rangeV;
                                    if (nh < best) {
                                        best = nh;
                                        bx = nx;
                                        by = ny;
                                    }
                                }
                            }
                            dx = dx + 1;
                        }
                        dy = dy + 1;
                    }
                    if (bx == cx && by == cy) {
                        return;
                    }
                    cx = bx;
                    cy = by;
                    steps = steps + 1;
                }
            }

            private static method classify(float v, float deepT, float oceanT, float beachT,
                                           float mountT, float snowT) returns Biome {
                if (v < deepT) {
                    return Biome.DeepOcean;
                }
                if (v < oceanT) {
                    return Biome.Ocean;
                }
                if (v < beachT) {
                    return Biome.Beach;
                }
                if (v < mountT) {
                    return Biome.Grassland;
                }
                if (v < snowT) {
                    return Biome.Mountain;
                }
                return Biome.Snow;
            }
        }
    }
}

import System.IO.Console;

// A harvestable node on the map. kind: 0 Tree->Wood, 1 Stone, 2 Iron, 3 Bush->Food, 4 Fauna->Food.
// A worker reserves a node while harvesting it; it deactivates once depleted.
program AgentsExe;

public bundle Agents {
    public namespace World {

        public class ResourceNode {
            public mutable int kind;
            public mutable int x;
            public mutable int y;
            public mutable int remaining;
            public mutable boolean alive;
            public mutable int reservedBy;

            public constructor ResourceNode(int kind, int x, int y, int cap) {
                this.kind = kind;
                this.x = x;
                this.y = y;
                this.remaining = cap;
                this.alive = true;
                this.reservedBy = -1;
            }

            // The stockpile resource this node yields (index into a ResourceBundle).
            public method gives() returns int {
                if (this.kind == 0) {
                    return 1;
                }
                if (this.kind == 1) {
                    return 3;
                }
                if (this.kind == 2) {
                    return 4;
                }
                return 0;
            }

            public method glyph() returns char {
                if (this.kind == 0) {
                    return 't';
                }
                if (this.kind == 1) {
                    return 's';
                }
                if (this.kind == 2) {
                    return 'i';
                }
                if (this.kind == 3) {
                    return 'b';
                }
                return 'f';
            }
        }
    }
}

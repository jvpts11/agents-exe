// A harvestable node at a grid cell: its kind, position, remaining amount, and (for fauna) whether it
// wanders. Reserved-by lets one worker claim it while harvesting. Individual objects, as in the
// original (separate from the tile arrays).
program AgentsExe;

public bundle Agents {
    public namespace World {

        public class ResourceNode {
            public mutable ResourceKind kind;
            public mutable int gx;
            public mutable int gy;
            public mutable int amount;
            public mutable boolean alive;
            public mutable boolean mobile;
            public mutable int reservedBy;

            public constructor ResourceNode(ResourceKind kind, int gx, int gy, int amount, boolean mobile) {
                this.kind = kind;
                this.gx = gx;
                this.gy = gy;
                this.amount = amount;
                this.alive = true;
                this.mobile = mobile;
                this.reservedBy = -1;
            }
        }
    }
}

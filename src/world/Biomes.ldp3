import System.IO.Console;

// Biome ordinals, stored as ints in the grid (kept as plain ints so they live in an int[] cheaply).
// 0 Ocean, 1 Beach, 2 Grassland, 3 Mountain, 4 Snow. Only Grassland and Beach are walkable.
program AgentsExe;

public bundle Agents {
    public namespace World {

        public class Biomes {
            public static method ocean() returns int {
                return 0;
            }
            public static method beach() returns int {
                return 1;
            }
            public static method grass() returns int {
                return 2;
            }
            public static method mountain() returns int {
                return 3;
            }
            public static method snow() returns int {
                return 4;
            }
            public static method glyph(int b) returns char {
                if (b == 0) {
                    return '~';
                }
                if (b == 1) {
                    return '.';
                }
                if (b == 2) {
                    return ' ';
                }
                if (b == 3) {
                    return '^';
                }
                return '*';
            }
        }
    }
}

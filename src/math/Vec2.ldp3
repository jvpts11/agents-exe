import System.IO.Console;

// An integer cell vector with value semantics (assignment copies) and overloaded operators, the way
// the original leans on UnityEngine.Vector2. World generation and agent movement add/subtract
// positions and measure distances through it.
program AgentsExe;

public bundle Agents {
    public namespace Math {

        public class Vec2 {
            public mutable int x;
            public mutable int y;

            public constructor Vec2(int x, int y) {
                this.x = x;
                this.y = y;
            }

            public operator + (Vec2 o) returns Vec2 {
                return new Vec2(this.x + o.x, this.y + o.y) on heap;
            }

            public operator - (Vec2 o) returns Vec2 {
                return new Vec2(this.x - o.x, this.y - o.y) on heap;
            }

            // Squared Euclidean distance -- avoids a sqrt and is all we need for nearest-of comparisons.
            public method dist2(Vec2 o) returns int {
                int dx = this.x - o.x;
                int dy = this.y - o.y;
                return dx * dx + dy * dy;
            }

            public method manhattan(Vec2 o) returns int {
                mutable int dx = this.x - o.x;
                mutable int dy = this.y - o.y;
                if (dx < 0) {
                    dx = 0 - dx;
                }
                if (dy < 0) {
                    dy = 0 - dy;
                }
                return dx + dy;
            }
        }
    }
}

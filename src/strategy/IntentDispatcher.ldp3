import Agents.People.Nation;
import Agents.Sim.Realm;

// Applies an Intent to the world (agents.exe IntentDispatcher). Records it on the nation and in the
// recent-events feed. Illegal intents are quietly rejected, matching the game.
program AgentsExe;

public bundle Agents {
    public namespace Strategy {

        public class IntentDispatcher {
            public static method apply(Nation* n, Intent* it, Realm* world) returns void {
                n.lastIntent = IType.name(it.type);
                n.lastReason = it.reason;
                if (it.type == 0) {
                    world.declareWar(n.id, it.targetNation);
                } else if (it.type == 1) {
                    world.makePeace(n.id, it.targetNation);
                } else if (it.type == 2) {
                    mutable int s = it.targetSize;
                    if (s > 60) {
                        s = 60;
                    }
                    if (s > n.desiredSoldiers) {
                        n.desiredSoldiers = s;
                    }
                } else if (it.type == 3) {
                    world.foundCity(n);
                } else if (it.type == 4) {
                    n.focusedRes = it.resource;
                } else if (it.type == 5) {
                    n.prioBuilding = it.buildingType;
                } else if (it.type == 6) {
                    if (n.enemies[it.targetNation]) {
                        n.attackTarget = it.targetNation;
                    }
                } else if (it.type == 7) {
                    world.conscript(n, it.count);
                } else if (it.type == 8) {
                    world.nameHeir(n);
                } else if (it.type == 9) {
                    n.attackTarget = -1;
                }
                n.addEvent($"[{world.year()}y] {IType.name(it.type)}: {it.reason}");
            }
        }
    }
}

// The strategic actions a nation's leader can decide on -- the actionable subset of the original's
// IntentType the Mock heuristic actually produces, plus the diplomacy intents the shipped game left as
// stubs (SendGift / DemandTribute / ProposeTrade / Observe / Fortify / Surrender), now real. The
// dispatcher (Realm.applyIntent) switches on this to turn a decision into state the tactical layer reads.
program AgentsExe;

public bundle Agents {
    public namespace Strategy {

        public enum IntentType {
            DeclareWar,
            MakePeace,
            BuildArmy,
            DisbandArmy,
            FoundCity,
            MakeAlliance,
            NameHeir,
            FocusResource,
            PrioritizeBuilding,
            Idle,
            AttackCity,
            Retreat,
            Conscript,
            SendGift,
            DemandTribute,
            ProposeTrade,
            Observe,
            Fortify,
            Surrender
        }
    }
}

// A strategic intention chosen by the Mock heuristic and applied by the dispatcher. `type` is the action
// (an IntentType); the optional fields are -1/empty when unused; `rulePath` records which cascade rule
// fired (R0..R5), shown in the intents feed.
program AgentsExe;

public bundle Agents {
    public namespace Strategy {

        public class Intent {
            public mutable IntentType type;
            public mutable int targetNation;    // DeclareWar / MakePeace / AttackCity target
            public mutable int targetSize;      // BuildArmy desired soldiers
            public mutable int resource;        // FocusResource: 0..5, else -1
            public mutable int building;        // PrioritizeBuilding: BuildingType ordinal, else -1
            public mutable int count;           // Conscript count
            public mutable String reason;
            public mutable String rulePath;

            public constructor Intent(IntentType type) {
                this.type = type;
                this.targetNation = -1;
                this.targetSize = 0;
                this.resource = -1;
                this.building = -1;
                this.count = 0;
                this.reason = "";
                this.rulePath = "";
            }
        }
    }
}

// One strategic order. Only the fields relevant to its type are meaningful.
program AgentsExe;

public bundle Agents {
    public namespace Strategy {

        public class Intent {
            public mutable int type;
            public mutable int targetNation;
            public mutable int targetSize;
            public mutable int resource;
            public mutable int buildingType;
            public mutable int count;
            public mutable String reason;
            public mutable String rulePath;

            public constructor Intent(int type) {
                this.type = type;
                this.targetNation = -1;
                this.targetSize = 0;
                this.resource = -1;
                this.buildingType = -1;
                this.count = 0;
                this.reason = "";
                this.rulePath = "";
            }
        }
    }
}

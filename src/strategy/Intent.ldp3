// A strategic intention chosen by the Mock heuristic and applied by the dispatcher. Type ids follow the
// original's IntentType ordinals (the actionable subset the Mock actually produces). Optional fields are
// -1 / empty when unused; `rulePath` records which cascade rule fired (R0..R5), for the intents feed.
program AgentsExe;

public bundle Agents {
    public namespace Strategy {

        public class Intent {
            public mutable int type;
            public mutable int targetNation;    // DeclareWar / MakePeace / AttackCity target
            public mutable int targetSize;      // BuildArmy desired soldiers
            public mutable int resource;        // FocusResource: 0..5, else -1
            public mutable int building;        // PrioritizeBuilding: BuildingType ordinal, else -1
            public mutable int count;           // Conscript count
            public mutable String reason;
            public mutable String rulePath;

            public constructor Intent(int type) {
                this.type = type;
                this.targetNation = -1;
                this.targetSize = 0;
                this.resource = -1;
                this.building = -1;
                this.count = 0;
                this.reason = "";
                this.rulePath = "";
            }

            // Actionable intent type ids (original IntentType ordinals).
            public static method declareWar() returns int {
                return 0;
            }
            public static method makePeace() returns int {
                return 1;
            }
            public static method buildArmy() returns int {
                return 2;
            }
            public static method disbandArmy() returns int {
                return 3;
            }
            public static method foundCity() returns int {
                return 4;
            }
            public static method makeAlliance() returns int {
                return 6;
            }
            public static method nameHeir() returns int {
                return 7;
            }
            public static method focusResource() returns int {
                return 9;
            }
            public static method prioritizeBuilding() returns int {
                return 10;
            }
            public static method idle() returns int {
                return 11;
            }
            public static method attackCity() returns int {
                return 15;
            }
            public static method retreat() returns int {
                return 16;
            }
            public static method conscript() returns int {
                return 17;
            }
        }
    }
}

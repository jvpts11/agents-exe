// The seven leader personalities that drive the Mock heuristic (Personality.cs), in ordinal order. A
// leader's personality is the primary switch in the decision cascade -- the proactive-war chances, the
// surrender rolls, the player-message obedience, and the peacetime default all branch on it. Unknown or
// missing personalities resolve to Stoic.
program AgentsExe;

public bundle Agents {
    public namespace Strategy {

        public enum Personality {
            Aggressive,
            Cautious,
            Expansionist,
            Mercantile,
            Pious,
            Cunning,
            Stoic;

            public method name() returns String {
                switch (this) {
                    case Personality.Aggressive {
                        return "Aggressive";
                    }
                    case Personality.Cautious {
                        return "Cautious";
                    }
                    case Personality.Expansionist {
                        return "Expansionist";
                    }
                    case Personality.Mercantile {
                        return "Mercantile";
                    }
                    case Personality.Pious {
                        return "Pious";
                    }
                    case Personality.Cunning {
                        return "Cunning";
                    }
                    default {
                        return "Stoic";
                    }
                }
            }

            // The proactive-war base chance (R3.5): only these four ever start a war unprovoked.
            public method proactiveWarChance() returns int {
                switch (this) {
                    case Personality.Aggressive {
                        return 25;
                    }
                    case Personality.Cunning {
                        return 15;
                    }
                    case Personality.Expansionist {
                        return 15;
                    }
                    case Personality.Pious {
                        return 8;
                    }
                    default {
                        return 0;
                    }
                }
            }

            // Map an ordinal (0..6, wrapped) to a personality -- the bridge from the seeded int a nation
            // draws for its leader's temperament to the enum the cascade actually branches on.
            public static method fromId(int id) returns Personality {
                int p = ((id % 7) + 7) % 7;
                switch (p) {
                    case 0 {
                        return Personality.Aggressive;
                    }
                    case 1 {
                        return Personality.Cautious;
                    }
                    case 2 {
                        return Personality.Expansionist;
                    }
                    case 3 {
                        return Personality.Mercantile;
                    }
                    case 4 {
                        return Personality.Pious;
                    }
                    case 5 {
                        return Personality.Cunning;
                    }
                    default {
                        return Personality.Stoic;
                    }
                }
            }
        }
    }
}

// Intent type ordinals (the subset agents.exe's IntentDispatcher actually implements + a few).
program AgentsExe;

public bundle Agents {
    public namespace Strategy {

        public class IType {
            public static method declareWar() returns int {
                return 0;
            }
            public static method makePeace() returns int {
                return 1;
            }
            public static method buildArmy() returns int {
                return 2;
            }
            public static method foundCity() returns int {
                return 3;
            }
            public static method focusResource() returns int {
                return 4;
            }
            public static method prioritizeBuilding() returns int {
                return 5;
            }
            public static method attackCity() returns int {
                return 6;
            }
            public static method conscript() returns int {
                return 7;
            }
            public static method nameHeir() returns int {
                return 8;
            }
            public static method retreat() returns int {
                return 9;
            }
            public static method idle() returns int {
                return 10;
            }
            public static method name(int t) returns String {
                if (t == 0) {
                    return "DeclareWar";
                }
                if (t == 1) {
                    return "MakePeace";
                }
                if (t == 2) {
                    return "BuildArmy";
                }
                if (t == 3) {
                    return "FoundCity";
                }
                if (t == 4) {
                    return "FocusResource";
                }
                if (t == 5) {
                    return "PrioritizeBuilding";
                }
                if (t == 6) {
                    return "AttackCity";
                }
                if (t == 7) {
                    return "Conscript";
                }
                if (t == 8) {
                    return "NameHeir";
                }
                if (t == 9) {
                    return "Retreat";
                }
                return "Idle";
            }
        }
    }
}

// Personality ordinals (agents.exe Personality). Drives the Leader's decision roll tables.
program AgentsExe;

public bundle Agents {
    public namespace People {

        public class Trait {
            public static method aggressive() returns int {
                return 0;
            }
            public static method cautious() returns int {
                return 1;
            }
            public static method expansionist() returns int {
                return 2;
            }
            public static method mercantile() returns int {
                return 3;
            }
            public static method pious() returns int {
                return 4;
            }
            public static method cunning() returns int {
                return 5;
            }
            public static method stoic() returns int {
                return 6;
            }
            public static method name(int p) returns String {
                if (p == 0) {
                    return "Aggressive";
                }
                if (p == 1) {
                    return "Cautious";
                }
                if (p == 2) {
                    return "Expansionist";
                }
                if (p == 3) {
                    return "Mercantile";
                }
                if (p == 4) {
                    return "Pious";
                }
                if (p == 5) {
                    return "Cunning";
                }
                return "Stoic";
            }
        }
    }
}

import System.Collections.ArrayList;
import Agents.Economy.Stockpile;
import Agents.Economy.Building;
import Agents.Economy.BuildingType;
import Agents.World.Grid;
import Agents.World.FlowField;
import Agents.Strategy.Personality;

// A nation: its identity, capital cell, banner colour, stockpile, capital flow-field, its buildings and
// the workers that belong to it. Colour comes from the fixed nation palette, keyed by id.
program AgentsExe;

public bundle Agents {
    public namespace People {

        public class Nation {
            public mutable int id;
            public mutable String name;
            public mutable int capX;
            public mutable int capY;
            public mutable int cr;
            public mutable int cg;
            public mutable int cb;
            public mutable ArrayList<Worker*> members;
            public mutable boolean alive;
            public mutable Stockpile* stock;
            public mutable FlowField* capFlow;   // BFS field toward the capital
            public mutable ArrayList<Building*> buildings;
            // --- strategic layer ---
            public mutable Personality personality;   // the leader's temperament (drives the Mock cascade)
            public mutable int desiredSoldiers;
            public mutable int warsWon;
            public mutable int warsLost;
            public mutable boolean[] atWar;      // atWar[otherNationId]
            public mutable boolean[] ally;       // ally[otherNationId] -- a standing non-aggression pact
            public mutable int focusedRes;       // FocusResource: 0..5, else -1
            public mutable int prioBuilding;     // PrioritizeBuilding: BuildingType ordinal, else -1
            public mutable int attackTarget;     // enemy nation id currently being assaulted, else -1
            public mutable int leaderIdx;        // index into Realm.workers of the reigning leader, -1 none
            public mutable int reigns;           // how many leaders have held the throne (succession count)
            public mutable float nextDecision;   // seconds until this nation's next strategic decision
            public mutable float warStartTime;   // clock time the current war began (for stalemate peace)
            public mutable int casualties;       // combat losses in the recent window
            public mutable String lastIntent;
            public mutable String lastReason;

            public constructor Nation(int id, String name, int capX, int capY, Grid* grid) {
                this.id = id;
                this.name = name;
                this.capX = capX;
                this.capY = capY;
                this.members = new ArrayList<Worker*>() on heap;
                this.buildings = new ArrayList<Building*>() on heap;
                this.alive = true;
                this.stock = new Stockpile() on heap;
                this.capFlow = new FlowField(grid, capX, capY) on heap;
                this.personality = Personality.fromId(id);
                this.desiredSoldiers = 0;
                this.warsWon = 0;
                this.warsLost = 0;
                this.atWar = new boolean[8]();
                this.ally = new boolean[8]();
                this.focusedRes = -1;
                this.prioBuilding = -1;
                this.attackTarget = -1;
                this.leaderIdx = -1;
                this.reigns = 0;
                this.nextDecision = 20.0 + cast<float>(id) * 8.0;   // staggered first decision
                this.warStartTime = 0.0;
                this.casualties = 0;
                this.lastIntent = "none";
                this.lastReason = "";
                this.setColor(id);
            }

            // Nation stats as computed properties (spec 8.4): read like fields -- nation.population,
            // nation.army, nation.isAtWar -- each derived from the roster / war table on read.
            public boolean isAtWar {
                get {
                    mutable int i = 0;
                    while (i < this.atWar.length()) {
                        if (this.atWar[i]) {
                            return true;
                        }
                        i = i + 1;
                    }
                    return false;
                }
            }

            public method firstEnemy() returns int {
                mutable int i = 0;
                while (i < this.atWar.length()) {
                    if (this.atWar[i]) {
                        return i;
                    }
                    i = i + 1;
                }
                return -1;
            }

            public int army {
                get {
                    mutable int c = 0;
                    mutable int i = 0;
                    while (i < this.members.size()) {
                        mutable Worker* w = this.members.get(i);
                        if (w.alive && (w.profession == 10 || w.profession == 11)) {
                            c = c + 1;
                        }
                        i = i + 1;
                    }
                    return c;
                }
            }

            // Count finished buildings of a type.
            public method countBuilding(BuildingType t) returns int {
                mutable int c = 0;
                mutable int i = 0;
                while (i < this.buildings.size()) {
                    mutable Building* b = this.buildings.get(i);
                    if (b.built && b.type == t) {
                        c = c + 1;
                    }
                    i = i + 1;
                }
                return c;
            }

            public destructor ~Nation() returns void {
                mutable int i = 0;
                while (i < this.buildings.size()) {
                    delete this.buildings.get(i);
                    i = i + 1;
                }
                delete this.stock;
                delete this.capFlow;
                delete this.atWar;
                delete this.ally;
            }

            // The fixed banner palette, keyed by nation id, exactly as the original's NationPalette
            // (16 hues, wrapped). The first four -- the default nations -- are red / blue / green / yellow.
            private method setColor(int id) returns void {
                int p = ((id % 16) + 16) % 16;
                if (p == 0) {
                    this.cr = 217;
                    this.cg = 51;
                    this.cb = 51;
                } else if (p == 1) {
                    this.cr = 51;
                    this.cg = 115;
                    this.cb = 217;
                } else if (p == 2) {
                    this.cr = 76;
                    this.cg = 191;
                    this.cb = 76;
                } else if (p == 3) {
                    this.cr = 242;
                    this.cg = 217;
                    this.cb = 64;
                } else if (p == 4) {
                    this.cr = 166;
                    this.cg = 77;
                    this.cb = 191;
                } else if (p == 5) {
                    this.cr = 64;
                    this.cg = 204;
                    this.cb = 204;
                } else if (p == 6) {
                    this.cr = 242;
                    this.cg = 140;
                    this.cb = 51;
                } else if (p == 7) {
                    this.cr = 242;
                    this.cg = 115;
                    this.cb = 179;
                } else if (p == 8) {
                    this.cr = 128;
                    this.cg = 77;
                    this.cb = 26;
                } else if (p == 9) {
                    this.cr = 140;
                    this.cg = 217;
                    this.cb = 64;
                } else if (p == 10) {
                    this.cr = 51;
                    this.cg = 128;
                    this.cb = 128;
                } else if (p == 11) {
                    this.cr = 191;
                    this.cg = 51;
                    this.cb = 128;
                } else if (p == 12) {
                    this.cr = 26;
                    this.cg = 51;
                    this.cb = 128;
                } else if (p == 13) {
                    this.cr = 140;
                    this.cg = 128;
                    this.cb = 77;
                } else if (p == 14) {
                    this.cr = 217;
                    this.cg = 179;
                    this.cb = 128;
                } else {
                    this.cr = 128;
                    this.cg = 140;
                    this.cb = 166;
                }
            }

            public int population {
                get {
                    mutable int n = 0;
                    mutable int i = 0;
                    while (i < this.members.size()) {
                        if (this.members.get(i).alive) {
                            n = n + 1;
                        }
                        i = i + 1;
                    }
                    return n;
                }
            }
        }
    }
}

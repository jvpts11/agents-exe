import System.Collections.ArrayList;
import Agents.Economy.Stockpile;
import Agents.World.Grid;
import Agents.World.FlowField;

// A nation: its identity, capital cell, banner colour, and the workers that belong to it. The economy,
// diplomacy, protagonist and war state land in later phases; this is the minimum an agent needs to be
// affiliated and tinted. Colour comes from the fixed nation palette, keyed by id.
program AgentsExe;

public bundle Agents {
    public namespace People {

        public class Nation {
            public mutable int id;
            public mutable String name;
            public mutable int capX;
            public mutable int capY;
            public mutable int cr;
            public mutable int cg;
            public mutable int cb;
            public mutable ArrayList<Worker*> members;
            public mutable boolean alive;
            public mutable Stockpile* stock;
            public mutable FlowField* capFlow;   // BFS field toward the capital

            public constructor Nation(int id, String name, int capX, int capY, Grid* grid) {
                this.id = id;
                this.name = name;
                this.capX = capX;
                this.capY = capY;
                this.members = new ArrayList<Worker*>() on heap;
                this.alive = true;
                this.stock = new Stockpile() on heap;
                this.capFlow = new FlowField(grid, capX, capY) on heap;
                this.setColor(id);
            }

            public destructor ~Nation() returns void {
                delete this.stock;
                delete this.capFlow;
            }

            // The fixed banner palette, keyed by nation id (NationPalette): seven distinct hues.
            private method setColor(int id) returns void {
                int p = id % 7;
                if (p == 0) {
                    this.cr = 219;
                    this.cg = 56;
                    this.cb = 51;
                } else if (p == 1) {
                    this.cr = 51;
                    this.cg = 122;
                    this.cb = 219;
                } else if (p == 2) {
                    this.cr = 235;
                    this.cg = 194;
                    this.cb = 41;
                } else if (p == 3) {
                    this.cr = 148;
                    this.cg = 66;
                    this.cb = 184;
                } else if (p == 4) {
                    this.cr = 41;
                    this.cg = 184;
                    this.cb = 158;
                } else if (p == 5) {
                    this.cr = 230;
                    this.cg = 133;
                    this.cb = 41;
                } else {
                    this.cr = 219;
                    this.cg = 110;
                    this.cb = 171;
                }
            }

            public method livingCount() returns int {
                mutable int n = 0;
                mutable int i = 0;
                while (i < this.members.size()) {
                    if (this.members.get(i).alive) {
                        n = n + 1;
                    }
                    i = i + 1;
                }
                return n;
            }
        }
    }
}

// The four isometric facings a worker's sprite can show, in the character atlas' row order. Movement
// chooses one from the velocity's sign quadrant (with a dead-zone, so a near-cardinal drift does not
// flip the sprite every frame); the renderer maps it to a sprite row via index().
program AgentsExe;

public bundle Agents {
    public namespace People {

        public enum Direction {
            NE,
            SE,
            SW,
            NW;

            // The sprite-row index (NE=0, SE=1, SW=2, NW=3), matching the character atlas layout.
            public method index() returns int {
                switch (this) {
                    case Direction.NE {
                        return 0;
                    }
                    case Direction.SE {
                        return 1;
                    }
                    case Direction.SW {
                        return 2;
                    }
                    default {
                        return 3;
                    }
                }
            }
        }
    }
}

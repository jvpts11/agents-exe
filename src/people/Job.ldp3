// Profession ordinals (agents.exe Profession, trimmed to the economy this build runs).
program AgentsExe;

public bundle Agents {
    public namespace People {

        public class Job {
            public static method civilian() returns int {
                return 0;
            }
            public static method woodcutter() returns int {
                return 1;
            }
            public static method farmer() returns int {
                return 2;
            }
            public static method stoneMiner() returns int {
                return 3;
            }
            public static method ironMiner() returns int {
                return 4;
            }
            public static method builder() returns int {
                return 5;
            }
            public static method sawyer() returns int {
                return 6;
            }
            public static method soldier() returns int {
                return 7;
            }
            public static method hunter() returns int {
                return 8;
            }
            public static method treePlanter() returns int {
                return 9;
            }
            public static method trader() returns int {
                return 10;
            }
            public static method general() returns int {
                return 11;
            }
            public static method name(int j) returns String {
                if (j == 0) {
                    return "Civilian";
                }
                if (j == 1) {
                    return "Woodcutter";
                }
                if (j == 2) {
                    return "Farmer";
                }
                if (j == 3) {
                    return "StoneMiner";
                }
                if (j == 4) {
                    return "IronMiner";
                }
                if (j == 5) {
                    return "Builder";
                }
                if (j == 6) {
                    return "Sawyer";
                }
                if (j == 7) {
                    return "Soldier";
                }
                if (j == 8) {
                    return "Hunter";
                }
                if (j == 9) {
                    return "TreePlanter";
                }
                if (j == 10) {
                    return "Trader";
                }
                return "General";
            }
        }
    }
}

// A worker agent. It holds a continuous grid-space position (rendering projects it isometrically), the
// nation it belongs to, its profession and facing, the survival state the original tracks (HP, hunger,
// age, lifetime), and the gathering-FSM state (its target node and what it is carrying home).
program AgentsExe;

public bundle Agents {
    public namespace People {

        public class Worker {
            public mutable float px;      // continuous position in grid space
            public mutable float py;
            public mutable int nationId;
            public mutable Profession profession;   // the worker's trade (drives its tick FSM)
            public mutable Direction dir;   // which way the sprite faces
            public mutable int hp;
            public mutable int hunger;     // 0..100, death at 100
            public mutable int thirst;     // 0..100, death at 100 (drink at a well or water's edge)
            public mutable int energy;     // 0..100, rest near home to recover
            public mutable boolean alive;
            // FSM / gathering state
            public mutable int targetNode;   // index into the resource list, -1 = none
            public mutable int carryRes;     // resource index being carried home, -1 = none
            public mutable int carryAmt;
            public mutable float workTimer;  // seconds accumulated harvesting
            public mutable float hungerTimer;// seconds accumulated toward the next hunger tick
            public mutable float thirstTimer;// seconds accumulated toward the next thirst tick
            public mutable float energyTimer;// seconds accumulated toward the next energy tick
            public mutable int wanderDir;    // held wander direction (0..8, mv-style), -1 = none
            public mutable float wanderTimer;// seconds left on the current wander direction
            public mutable float age;        // seconds lived
            public mutable float lifetime;   // seconds until old-age death

            public constructor Worker(int nationId, float px, float py, float lifetime) {
                this.px = px;
                this.py = py;
                this.nationId = nationId;
                this.profession = Profession.Civilian;
                this.dir = Direction.SE;
                this.hp = 100;
                this.hunger = 0;
                this.thirst = 0;
                this.energy = 100;
                this.alive = true;
                this.targetNode = -1;
                this.carryRes = -1;
                this.carryAmt = 0;
                this.workTimer = 0.0;
                this.hungerTimer = 0.0;
                this.thirstTimer = 0.0;
                this.energyTimer = 0.0;
                this.wanderDir = -1;
                this.wanderTimer = 0.0;
                this.age = 0.0;
                this.lifetime = lifetime;
            }

            // Life-stage read as computed properties (spec 8.4): field-like at the call site
            // (worker.isAdult, not worker.isAdult()), each derived from age on read.
            public boolean isChild {
                get {
                    return this.age < 60.0;
                }
            }
            public boolean isAdult {
                get {
                    return this.age >= 60.0 && this.age < this.lifetime * 0.85;
                }
            }

            // The original declares a third life stage (LifeStage.Elder) but never reaches it. Here it is
            // real: in the last ~15% of life a worker retires from labour and only wanders near home.
            public boolean isElder {
                get {
                    return this.age >= this.lifetime * 0.85;
                }
            }

            // 0 Child, 1 Adult, 2 Elder.
            public int stage {
                get {
                    if (this.age < 60.0) {
                        return 0;
                    }
                    if (this.isElder) {
                        return 2;
                    }
                    return 1;
                }
            }

            // True when the worker stands within Chebyshev distance r of cell (tx,ty). The worker knows
            // its own position, so proximity is its own question to answer.
            public method near(int tx, int ty, int r) returns boolean {
                mutable int dx = cast<int>(this.px) - tx;
                mutable int dy = cast<int>(this.py) - ty;
                if (dx < 0) {
                    dx = 0 - dx;
                }
                if (dy < 0) {
                    dy = 0 - dy;
                }
                return dx <= r && dy <= r;
            }

            // True when the worker stands on or right beside cell (tx,ty).
            public method adjacentTo(int tx, int ty) returns boolean {
                return this.near(tx, ty, 1);
            }
        }
    }
}

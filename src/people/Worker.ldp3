// A worker agent. It holds a continuous grid-space position (rendering projects it isometrically), the
// nation it belongs to, its profession and facing, and the survival state the original tracks: HP and
// hunger. The behaviour FSM, professions selector and movement land in the next slices; for now a
// worker exists, belongs to a nation, and can be drawn at its position.
program AgentsExe;

public bundle Agents {
    public namespace People {

        public class Worker {
            public mutable float px;      // continuous position in grid space
            public mutable float py;
            public mutable int nationId;
            public mutable int profession; // 0 = Civilian (Job ordinals arrive with the FSM)
            public mutable int dir;        // facing: 0 NE, 1 SE, 2 SW, 3 NW
            public mutable int hp;
            public mutable int hunger;     // 0..100, death at 100
            public mutable boolean alive;

            public constructor Worker(int nationId, float px, float py) {
                this.px = px;
                this.py = py;
                this.nationId = nationId;
                this.profession = 0;
                this.dir = 1;
                this.hp = 100;
                this.hunger = 0;
                this.alive = true;
            }
        }
    }
}

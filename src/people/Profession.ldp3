import Agents.World.ResourceKind;

// The twelve worker professions (Profession.cs), in ordinal order. The replica's agent FSM drives the
// gatherers, the builder and the military directly; the farm/sawmill/etc. trades are produced passively by
// their buildings, so Farmer/Sawyer/TreePlanter/Trader exist for completeness but are not yet assigned.
// Each profession classifies itself (soldier? gatherer?) and knows what it harvests, so the tick loop can
// branch on the enum rather than on magic ordinals.
program AgentsExe;

public bundle Agents {
    public namespace People {

        public enum Profession {
            Civilian,
            Woodcutter,
            Farmer,
            Hunter,
            Builder,
            Sawyer,
            TreePlanter,
            StoneMiner,
            IronMiner,
            Trader,
            Soldier,
            General;

            public method isSoldier() returns boolean {
                return this == Profession.Soldier || this == Profession.General;
            }

            // The professions that walk to a resource node and harvest it (the gatherer FSM).
            public method isGatherer() returns boolean {
                return this == Profession.Woodcutter || this == Profession.Hunter
                    || this == Profession.StoneMiner || this == Profession.IronMiner;
            }

            // The node kind a gatherer harvests (woodcutters fell trees by default).
            public method gatherKind() returns ResourceKind {
                switch (this) {
                    case Profession.StoneMiner {
                        return ResourceKind.StoneNode;
                    }
                    case Profession.IronMiner {
                        return ResourceKind.IronNode;
                    }
                    case Profession.Hunter {
                        return ResourceKind.Fauna;
                    }
                    default {
                        return ResourceKind.Tree;
                    }
                }
            }

            public method name() returns String {
                switch (this) {
                    case Profession.Woodcutter {
                        return "Woodcutter";
                    }
                    case Profession.Farmer {
                        return "Farmer";
                    }
                    case Profession.Hunter {
                        return "Hunter";
                    }
                    case Profession.Builder {
                        return "Builder";
                    }
                    case Profession.Sawyer {
                        return "Sawyer";
                    }
                    case Profession.TreePlanter {
                        return "Tree Planter";
                    }
                    case Profession.StoneMiner {
                        return "Stone Miner";
                    }
                    case Profession.IronMiner {
                        return "Iron Miner";
                    }
                    case Profession.Trader {
                        return "Trader";
                    }
                    case Profession.Soldier {
                        return "Soldier";
                    }
                    case Profession.General {
                        return "General";
                    }
                    default {
                        return "Civilian";
                    }
                }
            }

            // A starting mix of gatherers so the young economy moves (the full selector comes later).
            public static method startingFor(int k) returns Profession {
                int m = k % 6;
                switch (m) {
                    case 0 {
                        return Profession.Woodcutter;
                    }
                    case 1 {
                        return Profession.Woodcutter;
                    }
                    case 2 {
                        return Profession.StoneMiner;
                    }
                    case 3 {
                        return Profession.IronMiner;
                    }
                    case 4 {
                        return Profession.Hunter;
                    }
                    default {
                        return Profession.Civilian;
                    }
                }
            }
        }
    }
}

import System.Collections.ArrayList;
import System.IO.Console;
import Agents.World.Grid;
import Agents.World.Biome;
import Agents.World.Rng;
import Agents.World.Noise;
import Agents.World.FlowField;
import Agents.World.ResourceNode;
import Agents.World.ResourceKind;
import Agents.World.ResourceSeeder;
import Agents.People.Nation;
import Agents.People.Worker;
import Agents.Economy.Building;
import Agents.Economy.BuildingType;
import Agents.Strategy.MockHeuristic;
import Agents.Strategy.Intent;

// The simulation container and its tick. It owns the world grid, resource nodes, nations and workers,
// bootstraps a game from a seed (generate -> seat nations -> spawn workers), and advances everyone each
// tick: workers age and hunger, and the gatherers run the harvest loop -- seek the nearest reachable
// node of their trade, walk to it, work it, carry the yield home to the capital and deposit it. Movement
// is continuous in grid space; the return trip follows the capital's flow-field. Real-time: dt seconds.
program AgentsExe;

public bundle Agents {
    public namespace Sim {

        public class Realm {
            public mutable Grid* grid;
            public mutable ArrayList<ResourceNode*>* nodes;
            public mutable ArrayList<Nation*> nations;
            public mutable ArrayList<Worker*> workers;
            public mutable int seed;
            private mutable Rng* moveRng;
            private mutable float reproTimer;
            private mutable float prodTimer;
            public mutable float clock;          // seconds of simulated real-time elapsed
            private mutable float combatTimer;   // accumulates toward the next combat resolution
            public mutable ArrayList<String>* intentLog;   // rolling feed of notable strategic events

            public constructor Realm(int w, int h, int seed) {
                this.seed = seed;
                this.grid = new Grid(w, h, seed) on heap;
                this.nodes = ResourceSeeder.seed(this.grid, seed);
                this.nations = new ArrayList<Nation*>() on heap;
                this.workers = new ArrayList<Worker*>() on heap;
                this.moveRng = new Rng(seed ^ 7788) on heap;
                this.reproTimer = 0.0;
                this.prodTimer = 0.0;
                this.clock = 0.0;
                this.combatTimer = 0.0;
                this.intentLog = new ArrayList<String>() on heap;
                this.placeNations(4);
                this.spawnWorkers(50);
                this.assignLeaders();
            }

            // Seat the first leader of each nation: its eldest adult member. Later deaths trigger succession.
            private method assignLeaders() returns void {
                mutable int ni = 0;
                while (ni < this.nations.size()) {
                    this.electLeader(this.nations.get(ni));
                    ni = ni + 1;
                }
            }

            public destructor ~Realm() returns void {
                mutable int i = 0;
                while (i < this.workers.size()) {
                    delete this.workers.get(i);
                    i = i + 1;
                }
                i = 0;
                while (i < this.nations.size()) {
                    delete this.nations.get(i);
                    i = i + 1;
                }
                i = 0;
                while (i < this.nodes.size()) {
                    delete this.nodes.get(i);
                    i = i + 1;
                }
                delete this.nodes;
                delete this.grid;
                delete this.moveRng;
                delete this.intentLog;
            }

            // Real-time clock, faithful to the original (tick = whole simulated seconds, 60 ticks = 1 year).
            public method tickCount() returns int {
                return cast<int>(this.clock);
            }
            public method year() returns int {
                return this.tickCount() / 60;
            }

            // Nearest living worker to a grid cell within `r` cells (for mouse-picking); -1 if none.
            public method pickWorker(int gx, int gy, int r) returns int {
                mutable int best = -1;
                mutable int bestD = 2000000000;
                mutable int i = 0;
                while (i < this.workers.size()) {
                    mutable Worker* w = this.workers.get(i);
                    if (w.alive) {
                        mutable int dx = cast<int>(w.px) - gx;
                        mutable int dy = cast<int>(w.py) - gy;
                        if (dx < 0) {
                            dx = 0 - dx;
                        }
                        if (dy < 0) {
                            dy = 0 - dy;
                        }
                        if (dx <= r && dy <= r) {
                            int d = dx * dx + dy * dy;
                            if (d < bestD) {
                                bestD = d;
                                best = i;
                            }
                        }
                    }
                    i = i + 1;
                }
                return best;
            }

            // Nation whose capital is nearest a grid cell within `r` cells; -1 if none.
            public method pickNation(int gx, int gy, int r) returns int {
                mutable int best = -1;
                mutable int bestD = 2000000000;
                mutable int i = 0;
                while (i < this.nations.size()) {
                    mutable Nation* n = this.nations.get(i);
                    mutable int dx = n.capX - gx;
                    mutable int dy = n.capY - gy;
                    if (dx < 0) {
                        dx = 0 - dx;
                    }
                    if (dy < 0) {
                        dy = 0 - dy;
                    }
                    if (dx <= r && dy <= r) {
                        int d = dx * dx + dy * dy;
                        if (d < bestD) {
                            bestD = d;
                            best = i;
                        }
                    }
                    i = i + 1;
                }
                return best;
            }

            // Append a line to the strategic feed, keeping only the most recent entries.
            private method logEvent(String line) returns void {
                this.intentLog.add(line);
                while (this.intentLog.size() > 40) {
                    this.intentLog.removeAt(0);
                }
            }

            private static method nationName(int i) returns String {
                if (i == 0) {
                    return "Aurelia";
                }
                if (i == 1) {
                    return "Brenmark";
                }
                if (i == 2) {
                    return "Cindara";
                }
                if (i == 3) {
                    return "Dorne";
                }
                if (i == 4) {
                    return "Eldros";
                }
                if (i == 5) {
                    return "Farengar";
                }
                return "Gilneas";
            }

            private method placeNations(int count) returns void {
                mutable Rng rng = new Rng(this.seed ^ 90124) on stack;
                int w = this.grid.width;
                int h = this.grid.height;
                mutable int placed = 0;
                mutable int tries = 0;
                while (placed < count && tries < 200000) {
                    tries = tries + 1;
                    int cx = rng.nextInt(w);
                    int cy = rng.nextInt(h);
                    if (this.grid.biomeAt(cx, cy) == Biome.Grassland) {
                        mutable boolean ok = true;
                        mutable int k = 0;
                        while (k < this.nations.size()) {
                            mutable Nation* o = this.nations.get(k);
                            int dx = cx - o.capX;
                            int dy = cy - o.capY;
                            if (dx * dx + dy * dy < 6400) {
                                ok = false;
                            }
                            k = k + 1;
                        }
                        if (ok) {
                            mutable Nation* n = new Nation(placed, Realm.nationName(placed), cx, cy,
                                                           this.grid) on heap;
                            n.stock.add(0, 60);   // a starting kit to bootstrap building
                            n.stock.add(1, 40);
                            n.stock.add(2, 20);
                            n.stock.add(3, 10);
                            n.stock.add(5, 30);
                            n.buildings.add(new Building(BuildingType.Castle, cx - 1, cy, true) on heap);
                            n.buildings.add(new Building(BuildingType.TownHall, cx, cy, true) on heap);
                            n.buildings.add(new Building(BuildingType.Farm, cx + 1, cy, true) on heap);
                            n.buildings.add(new Building(BuildingType.House, cx, cy + 1, true) on heap);
                            this.nations.add(n);
                            placed = placed + 1;
                        }
                    }
                }
            }

            private method spawnWorkers(int per) returns void {
                mutable Rng rng = new Rng(this.seed ^ 51237) on stack;
                mutable int ni = 0;
                while (ni < this.nations.size()) {
                    mutable Nation* n = this.nations.get(ni);
                    mutable int spawned = 0;
                    mutable int att = 0;
                    while (spawned < per && att < per * 20) {
                        att = att + 1;
                        int sx = n.capX + rng.range(0 - 6, 6);
                        int sy = n.capY + rng.range(0 - 6, 6);
                        if (this.grid.walkable(sx, sy)) {
                            float life = cast<float>(rng.range(360, 540));
                            mutable Worker* wk = new Worker(n.id, cast<float>(sx) + 0.5,
                                                           cast<float>(sy) + 0.5, life) on heap;
                            wk.profession = Realm.startingProfession(spawned);
                            wk.age = 120.0;   // start as adults so the economy runs immediately
                            this.workers.add(wk);
                            n.members.add(wk);
                            spawned = spawned + 1;
                        }
                    }
                    ni = ni + 1;
                }
            }

            // A starting mix of gatherers so the economy moves (the full profession selector is later).
            private static method startingProfession(int k) returns int {
                int m = k % 6;
                if (m == 0 || m == 1) {
                    return 1;   // Woodcutter
                }
                if (m == 2) {
                    return 7;   // StoneMiner
                }
                if (m == 3) {
                    return 8;   // IronMiner
                }
                if (m == 4) {
                    return 3;   // Hunter
                }
                return 0;       // Civilian
            }

            // --- tick ---

            public method tick(float dt) returns void {
                this.clock = this.clock + dt;
                mutable int i = 0;
                while (i < this.workers.size()) {
                    this.tickWorker(this.workers.get(i), dt);
                    i = i + 1;
                }
                this.reproTimer = this.reproTimer + dt;
                while (this.reproTimer >= 3.0) {
                    this.reproTimer = this.reproTimer - 3.0;
                    this.reproduce();
                }
                this.prodTimer = this.prodTimer + dt;
                while (this.prodTimer >= 5.0) {
                    this.prodTimer = this.prodTimer - 5.0;
                    this.produce();
                    this.growth();
                    this.reassign();
                }
                this.strategyTick(dt);
            }

            // --- strategic layer: staggered per-nation decisions, war, siege, conquest ---

            // Each living nation's leader runs the Mock heuristic on its own ~45s clock; the resulting
            // Intent is executed at once. First decisions are staggered (nextDecision seeded per id) so
            // the realms do not all move in lockstep.
            private method strategyTick(float dt) returns void {
                mutable int ni = 0;
                while (ni < this.nations.size()) {
                    mutable Nation* n = this.nations.get(ni);
                    if (n.alive) {
                        this.checkSuccession(n);
                        if (n.alive) {
                            n.nextDecision = n.nextDecision - dt;
                            if (n.nextDecision <= 0.0) {
                                n.nextDecision = 45.0;
                                mutable Intent* it = MockHeuristic.decide(this.nations, n,
                                    cast<int>(this.clock * 4.0), this.seed, this.clock);
                                this.applyIntent(n, it);
                                delete it;
                            }
                        }
                    }
                    ni = ni + 1;
                }
                this.combatTimer = this.combatTimer + dt;
                while (this.combatTimer >= 1.0) {
                    this.combatTimer = this.combatTimer - 1.0;
                    this.resolveConquests();
                }
            }

            private method applyIntent(Nation* n, Intent* it) returns void {
                n.lastIntent = it.rulePath;
                n.lastReason = it.reason;
                int t = it.type;
                if (t == Intent.declareWar() || t == Intent.attackCity()) {
                    this.beginWar(n, it.targetNation);
                } else if (t == Intent.makePeace()) {
                    this.endWar(n, it.targetNation);
                } else if (t == Intent.buildArmy()) {
                    mutable int want = it.targetSize;
                    if (want < 0) {
                        want = 0;
                    }
                    n.desiredSoldiers = want;
                    this.conscript(n, want - n.soldierCount());
                } else if (t == Intent.conscript()) {
                    this.conscript(n, it.count);
                } else if (t == Intent.disbandArmy()) {
                    n.desiredSoldiers = 0;
                    n.attackTarget = -1;
                    this.disband(n);
                } else if (t == Intent.focusResource()) {
                    n.focusedRes = it.resource;
                } else if (t == Intent.prioritizeBuilding()) {
                    n.prioBuilding = it.building;
                    if (!this.hasBlueprint(n)) {
                        this.placeBlueprint(n, Realm.buildingOfId(it.building));
                    }
                }
                // foundCity / nameHeir / idle: no state change yet
            }

            private static method buildingOfId(int id) returns BuildingType {
                if (id == 2) {
                    return BuildingType.Farm;
                }
                if (id == 3) {
                    return BuildingType.HuntersLodge;
                }
                if (id == 4) {
                    return BuildingType.Sawmill;
                }
                if (id == 6) {
                    return BuildingType.HouseMedium;
                }
                if (id == 7) {
                    return BuildingType.HouseLarge;
                }
                if (id == 8) {
                    return BuildingType.Barracks;
                }
                return BuildingType.House;
            }

            // Declare (or press) a war: both sides enter the war, mobilise a levy, and the aggressor marks
            // the enemy capital as its assault target.
            private method beginWar(Nation* n, int enemyId) returns void {
                if (enemyId < 0 || enemyId >= this.nations.size() || enemyId == n.id) {
                    return;
                }
                mutable Nation* e = this.nations.get(enemyId);
                if (!e.alive) {
                    return;
                }
                if (!n.atWar[enemyId]) {
                    n.atWar[enemyId] = true;
                    n.warStartTime = this.clock;
                    n.casualties = 0;
                    this.logEvent($"Y{this.year()}: {n.name} declares war on {e.name}");
                }
                if (!e.atWar[n.id]) {
                    e.atWar[n.id] = true;
                    e.warStartTime = this.clock;
                    e.casualties = 0;
                }
                n.attackTarget = enemyId;
                if (n.desiredSoldiers < 12) {
                    n.desiredSoldiers = 12;
                }
                if (e.desiredSoldiers < 10) {
                    e.desiredSoldiers = 10;
                }
                this.conscript(n, n.desiredSoldiers - n.soldierCount());
                this.conscript(e, e.desiredSoldiers - e.soldierCount());
            }

            private method endWar(Nation* n, int enemyId) returns void {
                if (enemyId < 0 || enemyId >= this.nations.size()) {
                    return;
                }
                mutable Nation* e = this.nations.get(enemyId);
                if (n.atWar[enemyId]) {
                    this.logEvent($"Y{this.year()}: {n.name} makes peace with {e.name}");
                }
                n.atWar[enemyId] = false;
                if (n.attackTarget == enemyId) {
                    n.attackTarget = -1;
                }
                e.atWar[n.id] = false;
                if (e.attackTarget == n.id) {
                    e.attackTarget = -1;
                }
            }

            // Turn idle adults into soldiers, up to `count`.
            private method conscript(Nation* n, int count) returns void {
                if (count <= 0) {
                    return;
                }
                mutable int done = 0;
                mutable int i = 0;
                while (i < n.members.size() && done < count) {
                    mutable Worker* w = n.members.get(i);
                    if (w.alive && w.isAdult() && w.profession != 10 && w.profession != 11
                            && w.carryRes < 0) {
                        w.profession = 10;   // Soldier
                        w.targetNode = -1;
                        done = done + 1;
                    }
                    i = i + 1;
                }
            }

            private method disband(Nation* n) returns void {
                mutable int i = 0;
                while (i < n.members.size()) {
                    mutable Worker* w = n.members.get(i);
                    if (w.alive && (w.profession == 10 || w.profession == 11)) {
                        w.profession = 0;
                    }
                    i = i + 1;
                }
            }

            private static method isSoldier(int prof) returns boolean {
                return prof == 10 || prof == 11;
            }

            // Succession: if the leader has died (or none is seated), crown the eldest adult -- the heir; if
            // no adult remains, any survivor; if the bloodline is spent, the nation dissolves. A new leader
            // may carry a different temperament, so the realm's policy can swing from one reign to the next.
            private method checkSuccession(Nation* n) returns void {
                boolean ok = n.leaderIdx >= 0 && n.leaderIdx < this.workers.size()
                          && this.workers.get(n.leaderIdx).alive;
                if (ok) {
                    return;
                }
                boolean firstReign = n.leaderIdx < 0 && n.reigns == 0;
                this.electLeader(n);
                if (n.leaderIdx < 0) {
                    this.dissolve(n);
                    return;
                }
                if (!firstReign) {
                    n.reigns = n.reigns + 1;
                    n.personality = this.moveRng.nextInt(7);   // the heir's own temperament
                    n.lastIntent = "succession";
                    n.lastReason = "A new leader takes the throne.";
                    n.nextDecision = 3.0;   // the new ruler acts soon
                    this.logEvent($"Y{this.year()}: {n.name} crowns a new leader");
                }
            }

            // Crown the eldest living adult of the nation (its members are workers of this nationId).
            private method electLeader(Nation* n) returns void {
                mutable int best = -1;
                mutable float bestAge = 0.0 - 1.0;
                mutable int i = 0;
                while (i < this.workers.size()) {
                    mutable Worker* w = this.workers.get(i);
                    if (w.alive && w.nationId == n.id && w.isAdult() && w.age > bestAge) {
                        bestAge = w.age;
                        best = i;
                    }
                    i = i + 1;
                }
                if (best < 0) {
                    i = 0;
                    while (i < this.workers.size() && best < 0) {
                        mutable Worker* w = this.workers.get(i);
                        if (w.alive && w.nationId == n.id) {
                            best = i;
                        }
                        i = i + 1;
                    }
                }
                n.leaderIdx = best;
            }

            // The line has ended and no conqueror claimed them: the nation quietly dissolves.
            private method dissolve(Nation* n) returns void {
                n.alive = false;
                n.leaderIdx = -1;
                n.attackTarget = -1;
                this.logEvent($"Y{this.year()}: {n.name} fades into ruin");
                mutable int k = 0;
                while (k < this.nations.size()) {
                    mutable Nation* o = this.nations.get(k);
                    if (n.id < o.atWar.length()) {
                        o.atWar[n.id] = false;
                        if (o.attackTarget == n.id) {
                            o.attackTarget = -1;
                        }
                    }
                    if (o.id < n.atWar.length()) {
                        n.atWar[o.id] = false;
                    }
                    k = k + 1;
                }
            }

            // Population growth (Worldbox-style): a nation with food to spare and room under the cap
            // grows children near its capital, who wander until they come of age and take up a trade.
            private method reproduce() returns void {
                mutable int ni = 0;
                while (ni < this.nations.size()) {
                    mutable Nation* n = this.nations.get(ni);
                    if (n.alive) {
                        int pop = n.livingCount();
                        mutable int need = pop / 8;
                        if (need < 10) {
                            need = 10;
                        }
                        if (pop < 150 && n.stock.get(0) >= need) {
                            int births = pop / 40 + 1;
                            mutable int b = 0;
                            while (b < births) {
                                this.spawnChild(n);
                                b = b + 1;
                            }
                        }
                    }
                    ni = ni + 1;
                }
            }

            private method spawnChild(Nation* n) returns void {
                mutable int att = 0;
                while (att < 20) {
                    att = att + 1;
                    int sx = n.capX + this.moveRng.range(0 - 5, 5);
                    int sy = n.capY + this.moveRng.range(0 - 5, 5);
                    if (this.grid.walkable(sx, sy)) {
                        float life = cast<float>(this.moveRng.range(360, 540));
                        mutable Worker* wk = new Worker(n.id, cast<float>(sx) + 0.5,
                                                       cast<float>(sy) + 0.5, life) on heap;
                        wk.profession = Realm.startingProfession(this.workers.size());
                        this.workers.add(wk);
                        n.members.add(wk);
                        return;
                    }
                }
            }

            private method tickWorker(Worker* wk, float dt) returns void {
                if (!wk.alive) {
                    return;
                }
                wk.age = wk.age + dt;
                if (wk.age >= wk.lifetime) {
                    wk.alive = false;
                    return;
                }
                // Hunger: +1 every 7s; starve at 100; eat from the nation store when hungry.
                wk.hungerTimer = wk.hungerTimer + dt;
                while (wk.hungerTimer >= 7.0) {
                    wk.hungerTimer = wk.hungerTimer - 7.0;
                    wk.hunger = wk.hunger + 1;
                }
                if (wk.hunger >= 100) {
                    wk.alive = false;
                    return;
                }
                mutable Nation* n = this.nations.get(wk.nationId);
                if (wk.hunger >= 30 && n.stock.get(0) >= 1) {
                    n.stock.spend(0, 1);
                    wk.hunger = 0;
                }
                if (!wk.isAdult()) {
                    this.wander(wk, dt);
                    return;
                }
                if (Realm.isSoldier(wk.profession)) {
                    this.tickSoldier(n, wk, dt);
                    return;
                }
                if (wk.profession == 4) {
                    this.tickBuilder(n, wk, dt);
                    return;
                }
                if (!Realm.isGatherer(wk.profession)) {
                    this.wander(wk, dt);
                    return;
                }
                this.tickGatherer(n, wk, dt);
            }

            private method tickGatherer(Nation* n, Worker* wk, float dt) returns void {
                // Carrying: head home to the capital and deposit.
                if (wk.carryRes >= 0) {
                    if (this.adjacentCell(wk, n.capX, n.capY)) {
                        n.stock.add(wk.carryRes, wk.carryAmt);
                        wk.carryRes = -1;
                        wk.carryAmt = 0;
                    } else {
                        this.moveViaFlow(wk, n.capFlow, dt);
                    }
                    return;
                }
                // Need a target node.
                if (wk.targetNode < 0 || !this.nodeValid(wk.targetNode)) {
                    wk.targetNode = this.findNode(wk, Realm.gatherKind(wk.profession), n.capFlow);
                    if (wk.targetNode < 0) {
                        this.wander(wk, dt);
                        return;
                    }
                    mutable ResourceNode* tn = this.nodes.get(wk.targetNode);
                    tn.reservedBy = wk.nationId;
                }
                mutable ResourceNode* node = this.nodes.get(wk.targetNode);
                if (this.adjacentCell(wk, node.gx, node.gy)) {
                    wk.workTimer = wk.workTimer + dt;
                    if (wk.workTimer >= 3.0) {
                        wk.workTimer = 0.0;
                        mutable int got = 10;
                        if (got > node.amount) {
                            got = node.amount;
                        }
                        node.amount = node.amount - got;
                        wk.carryRes = Realm.resIndex(node.kind);
                        wk.carryAmt = got;
                        if (node.amount <= 0) {
                            node.alive = false;
                        }
                        node.reservedBy = -1;
                        wk.targetNode = -1;
                    }
                } else {
                    this.moveToward(wk, node.gx, node.gy, dt);
                }
            }

            // --- military ---

            // A soldier marches on its nation's assault target and besieges the enemy capital; with no war
            // it garrisons its own capital.
            private method tickSoldier(Nation* n, Worker* wk, float dt) returns void {
                if (n.attackTarget < 0 || n.attackTarget >= this.nations.size()) {
                    if (this.nearCell(wk, n.capX, n.capY, 4)) {
                        this.wander(wk, dt);
                    } else {
                        this.moveToward(wk, n.capX, n.capY, dt);
                    }
                    return;
                }
                mutable Nation* e = this.nations.get(n.attackTarget);
                if (!e.alive) {
                    n.attackTarget = -1;
                    return;
                }
                if (this.nearCell(wk, e.capX, e.capY, 2)) {
                    this.siege(n, e, wk, dt);
                } else {
                    this.moveToward(wk, e.capX, e.capY, dt);
                }
            }

            // Resolve one soldier's strike each ~second: cut down a nearby defender (who fights back if
            // armed), else batter the nearest enemy building. Casualties feed the war's stalemate/collapse.
            private method siege(Nation* n, Nation* e, Worker* wk, float dt) returns void {
                wk.workTimer = wk.workTimer + dt;
                if (wk.workTimer < 1.0) {
                    return;
                }
                wk.workTimer = 0.0;
                int di = this.nearestEnemyWorker(e, wk, 3);
                if (di >= 0) {
                    mutable Worker* def = e.members.get(di);
                    def.hp = def.hp - 34;
                    if (def.hp <= 0) {
                        def.alive = false;
                        e.casualties = e.casualties + 1;
                    }
                    if (Realm.isSoldier(def.profession)) {
                        wk.hp = wk.hp - 25;
                        if (wk.hp <= 0) {
                            wk.alive = false;
                            n.casualties = n.casualties + 1;
                        }
                    }
                    return;
                }
                int bi = this.nearestBuilding(e, wk);
                if (bi >= 0) {
                    mutable Building* b = e.buildings.get(bi);
                    b.hp = b.hp - 20;
                    if (b.hp <= 0) {
                        this.destroyBuilding(e, bi);
                    }
                }
            }

            // Nearest living enemy member within `r` cells of the soldier, else -1.
            private method nearestEnemyWorker(Nation* e, Worker* wk, int r) returns int {
                int cx = cast<int>(wk.px);
                int cy = cast<int>(wk.py);
                mutable int best = -1;
                mutable int bestD = 2000000000;
                mutable int i = 0;
                while (i < e.members.size()) {
                    mutable Worker* w = e.members.get(i);
                    if (w.alive) {
                        mutable int dx = cast<int>(w.px) - cx;
                        mutable int dy = cast<int>(w.py) - cy;
                        if (dx < 0) {
                            dx = 0 - dx;
                        }
                        if (dy < 0) {
                            dy = 0 - dy;
                        }
                        if (dx <= r && dy <= r) {
                            int d = dx * dx + dy * dy;
                            if (d < bestD) {
                                bestD = d;
                                best = i;
                            }
                        }
                    }
                    i = i + 1;
                }
                return best;
            }

            private method nearestBuilding(Nation* e, Worker* wk) returns int {
                int cx = cast<int>(wk.px);
                int cy = cast<int>(wk.py);
                mutable int best = -1;
                mutable int bestD = 2000000000;
                mutable int i = 0;
                while (i < e.buildings.size()) {
                    mutable Building* b = e.buildings.get(i);
                    if (b.built) {
                        int dx = b.gx - cx;
                        int dy = b.gy - cy;
                        int d = dx * dx + dy * dy;
                        if (d < bestD) {
                            bestD = d;
                            best = i;
                        }
                    }
                    i = i + 1;
                }
                return best;
            }

            private method destroyBuilding(Nation* e, int idx) returns void {
                delete e.buildings.get(idx);
                e.buildings.removeAt(idx);
            }

            // The seats of power (Castle / TownHall) still standing; zero means the nation has fallen.
            private method countSeats(Nation* n) returns int {
                mutable int c = 0;
                mutable int i = 0;
                while (i < n.buildings.size()) {
                    mutable Building* b = n.buildings.get(i);
                    if (b.built && (b.type == BuildingType.Castle || b.type == BuildingType.TownHall)) {
                        c = c + 1;
                    }
                    i = i + 1;
                }
                return c;
            }

            // Test every war for a decisive result: a nation with no seats, too few people, or that has bled
            // out over a long war is conquered by its aggressor.
            private method resolveConquests() returns void {
                mutable int ni = 0;
                while (ni < this.nations.size()) {
                    mutable Nation* e = this.nations.get(ni);
                    if (e.alive) {
                        int agg = e.firstEnemy();
                        if (agg >= 0 && agg < this.nations.size()) {
                            mutable Nation* n = this.nations.get(agg);
                            boolean noSeats = this.countSeats(e) == 0;
                            boolean tiny = e.livingCount() < 10;
                            boolean bledOut = (this.clock - e.warStartTime) > 300.0
                                            && e.casualties > n.casualties * 2 + 6;
                            if (n.alive && (noSeats || tiny || bledOut)) {
                                this.conquer(n, e);
                            }
                        }
                    }
                    ni = ni + 1;
                }
            }

            // Absorb the loser: its survivors defect to the winner, it leaves every war, and it is struck
            // from the living nations.
            private method conquer(Nation* winner, Nation* loser) returns void {
                winner.warsWon = winner.warsWon + 1;
                loser.warsLost = loser.warsLost + 1;
                this.logEvent($"Y{this.year()}: {winner.name} CONQUERS {loser.name}!");
                mutable int i = 0;
                while (i < loser.members.size()) {
                    mutable Worker* w = loser.members.get(i);
                    if (w.alive) {
                        w.nationId = winner.id;
                        if (Realm.isSoldier(w.profession)) {
                            w.profession = 0;
                        }
                        w.targetNode = -1;
                        w.carryRes = -1;
                        winner.members.add(w);
                    }
                    i = i + 1;
                }
                loser.alive = false;
                mutable int k = 0;
                while (k < this.nations.size()) {
                    mutable Nation* o = this.nations.get(k);
                    if (loser.id < o.atWar.length()) {
                        o.atWar[loser.id] = false;
                        if (o.attackTarget == loser.id) {
                            o.attackTarget = -1;
                        }
                    }
                    if (o.id < loser.atWar.length()) {
                        loser.atWar[o.id] = false;
                    }
                    k = k + 1;
                }
                loser.attackTarget = -1;
            }

            private method nearCell(Worker* wk, int tx, int ty, int r) returns boolean {
                mutable int dx = cast<int>(wk.px) - tx;
                mutable int dy = cast<int>(wk.py) - ty;
                if (dx < 0) {
                    dx = 0 - dx;
                }
                if (dy < 0) {
                    dy = 0 - dy;
                }
                return dx <= r && dy <= r;
            }

            // --- helpers ---

            private static method isGatherer(int prof) returns boolean {
                return prof == 1 || prof == 7 || prof == 8 || prof == 3;
            }

            private static method gatherKind(int prof) returns ResourceKind {
                if (prof == 7) {
                    return ResourceKind.StoneNode;
                }
                if (prof == 8) {
                    return ResourceKind.IronNode;
                }
                if (prof == 3) {
                    return ResourceKind.Fauna;
                }
                return ResourceKind.Tree;
            }

            private static method resIndex(ResourceKind k) returns int {
                if (k == ResourceKind.StoneNode) {
                    return 2;
                }
                if (k == ResourceKind.IronNode) {
                    return 3;
                }
                if (k == ResourceKind.Tree) {
                    return 1;
                }
                return 0;   // Bush / Fauna -> Food
            }

            private method nodeValid(int idx) returns boolean {
                if (idx < 0 || idx >= this.nodes.size()) {
                    return false;
                }
                return this.nodes.get(idx).alive;
            }

            // Nearest free node of a kind the worker's capital can reach over land.
            private method findNode(Worker* wk, ResourceKind kind, FlowField* flow) returns int {
                int cx = cast<int>(wk.px);
                int cy = cast<int>(wk.py);
                mutable int best = -1;
                mutable int bestD = 2000000000;
                mutable int i = 0;
                while (i < this.nodes.size()) {
                    mutable ResourceNode* nd = this.nodes.get(i);
                    if (nd.alive && nd.kind == kind && nd.reservedBy < 0 && flow.reachable(nd.gx, nd.gy)) {
                        int dx = nd.gx - cx;
                        int dy = nd.gy - cy;
                        int d = dx * dx + dy * dy;
                        if (d < bestD) {
                            bestD = d;
                            best = i;
                        }
                    }
                    i = i + 1;
                }
                return best;
            }

            private method adjacentCell(Worker* wk, int tx, int ty) returns boolean {
                mutable int dx = cast<int>(wk.px) - tx;
                mutable int dy = cast<int>(wk.py) - ty;
                if (dx < 0) {
                    dx = 0 - dx;
                }
                if (dy < 0) {
                    dy = 0 - dy;
                }
                return dx <= 1 && dy <= 1;
            }

            // Move continuously toward a target cell centre at walking speed; face the movement.
            private method moveToward(Worker* wk, int tcx, int tcy, float dt) returns void {
                float tx = cast<float>(tcx) + 0.5;
                float ty = cast<float>(tcy) + 0.5;
                float dx = tx - wk.px;
                float dy = ty - wk.py;
                float d = Noise.sqrtF(dx * dx + dy * dy);
                float spd = 1.5 * dt;
                if (d <= spd || d < 0.0001) {
                    if (this.grid.walkable(tcx, tcy)) {
                        wk.px = tx;
                        wk.py = ty;
                    }
                } else {
                    float nx = wk.px + dx / d * spd;
                    float ny = wk.py + dy / d * spd;
                    if (this.grid.walkable(cast<int>(nx), cast<int>(ny))) {
                        wk.px = nx;
                        wk.py = ny;
                    }
                }
                wk.dir = Realm.faceOf(dx, dy);
            }

            // Follow a flow-field one cell at a time toward its target.
            private method moveViaFlow(Worker* wk, FlowField* flow, float dt) returns void {
                int cx = cast<int>(wk.px);
                int cy = cast<int>(wk.py);
                int packed = flow.stepToward(cx, cy);
                int sdx = FlowField.stepDx(packed);
                int sdy = FlowField.stepDy(packed);
                if (sdx == 0 && sdy == 0) {
                    this.moveToward(wk, flow.targetX, flow.targetY, dt);
                } else {
                    this.moveToward(wk, cx + sdx, cy + sdy, dt);
                }
            }

            private method wander(Worker* wk, float dt) returns void {
                int mv = this.moveRng.nextInt(9);
                int mx = (mv % 3) - 1;
                int my = (mv / 3) - 1;
                this.moveToward(wk, cast<int>(wk.px) + mx, cast<int>(wk.py) + my, dt);
            }

            private static method faceOf(float dx, float dy) returns int {
                if (dx >= 0.0 && dy >= 0.0) {
                    return 0;   // NE
                }
                if (dx >= 0.0 && dy < 0.0) {
                    return 1;   // SE
                }
                if (dx < 0.0 && dy < 0.0) {
                    return 2;   // SW
                }
                return 3;       // NW
            }

            // --- economy: production, growth, construction ---

            private method produce() returns void {
                mutable int ni = 0;
                while (ni < this.nations.size()) {
                    mutable Nation* n = this.nations.get(ni);
                    if (n.alive) {
                        int food = n.countBuilding(BuildingType.Farm) * 4
                                 + n.countBuilding(BuildingType.HuntersLodge) * 3;
                        n.stock.add(0, food);
                        int cap = n.countBuilding(BuildingType.Sawmill) * 3;
                        mutable int wood = n.stock.get(1);
                        if (wood > cap) {
                            wood = cap;
                        }
                        if (wood > 0) {
                            n.stock.spend(1, wood);
                            n.stock.add(5, wood * 4);
                        }
                    }
                    ni = ni + 1;
                }
            }

            private method growth() returns void {
                mutable int ni = 0;
                while (ni < this.nations.size()) {
                    mutable Nation* n = this.nations.get(ni);
                    if (n.alive && !this.hasBlueprint(n)) {
                        int pop = n.livingCount();
                        int housingCap = n.countBuilding(BuildingType.House) * 2
                                       + n.countBuilding(BuildingType.HouseMedium) * 4
                                       + n.countBuilding(BuildingType.HouseLarge) * 8;
                        if (pop + 2 > housingCap) {
                            this.placeBlueprint(n, BuildingType.House);
                        } else if (n.countBuilding(BuildingType.Farm) < 2) {
                            this.placeBlueprint(n, BuildingType.Farm);
                        } else if (n.countBuilding(BuildingType.Sawmill) < 1) {
                            this.placeBlueprint(n, BuildingType.Sawmill);
                        } else if (n.countBuilding(BuildingType.HuntersLodge) < 1) {
                            this.placeBlueprint(n, BuildingType.HuntersLodge);
                        } else if (n.countBuilding(BuildingType.Farm) < 4) {
                            this.placeBlueprint(n, BuildingType.Farm);
                        }
                    }
                    ni = ni + 1;
                }
            }

            private method hasBlueprint(Nation* n) returns boolean {
                mutable int i = 0;
                while (i < n.buildings.size()) {
                    if (!n.buildings.get(i).built) {
                        return true;
                    }
                    i = i + 1;
                }
                return false;
            }

            private method placeBlueprint(Nation* n, BuildingType t) returns void {
                if (n.stock.get(5) < t.costPlanks() || n.stock.get(2) < t.costStone()
                        || n.stock.get(3) < t.costIron()) {
                    return;
                }
                int f = t.footprint();
                mutable int att = 0;
                while (att < 40) {
                    att = att + 1;
                    int bx = n.capX + this.moveRng.range(0 - 9, 9);
                    int by = n.capY + this.moveRng.range(0 - 9, 9);
                    if (this.footprintFree(n, bx, by, f)) {
                        n.stock.spend(5, t.costPlanks());
                        n.stock.spend(2, t.costStone());
                        n.stock.spend(3, t.costIron());
                        n.buildings.add(new Building(t, bx, by, false) on heap);
                        return;
                    }
                }
            }

            private method footprintFree(Nation* n, int bx, int by, int f) returns boolean {
                mutable int yy = 0;
                while (yy < f) {
                    mutable int xx = 0;
                    while (xx < f) {
                        if (!this.grid.walkable(bx + xx, by + yy)) {
                            return false;
                        }
                        xx = xx + 1;
                    }
                    yy = yy + 1;
                }
                mutable int i = 0;
                while (i < n.buildings.size()) {
                    mutable Building* o = n.buildings.get(i);
                    int dx = o.gx - bx;
                    int dy = o.gy - by;
                    if (dx > 0 - 3 && dx < f + 2 && dy > 0 - 3 && dy < f + 2) {
                        return false;
                    }
                    i = i + 1;
                }
                return true;
            }

            private method findBlueprint(Nation* n, Worker* wk) returns int {
                int cx = cast<int>(wk.px);
                int cy = cast<int>(wk.py);
                mutable int best = -1;
                mutable int bestD = 2000000000;
                mutable int i = 0;
                while (i < n.buildings.size()) {
                    mutable Building* b = n.buildings.get(i);
                    if (!b.built) {
                        int dx = b.gx - cx;
                        int dy = b.gy - cy;
                        int d = dx * dx + dy * dy;
                        if (d < bestD) {
                            bestD = d;
                            best = i;
                        }
                    }
                    i = i + 1;
                }
                return best;
            }

            private method tickBuilder(Nation* n, Worker* wk, float dt) returns void {
                int bi = this.findBlueprint(n, wk);
                if (bi < 0) {
                    this.wander(wk, dt);
                    return;
                }
                mutable Building* bp = n.buildings.get(bi);
                if (this.adjacentCell(wk, bp.gx, bp.gy)) {
                    bp.progress = bp.progress + dt;
                    if (bp.progress >= 8.0) {
                        bp.markBuilt();
                    }
                } else {
                    this.moveToward(wk, bp.gx, bp.gy, dt);
                }
            }

            private method countJob(Nation* n, int prof) returns int {
                mutable int c = 0;
                mutable int i = 0;
                while (i < n.members.size()) {
                    mutable Worker* w = n.members.get(i);
                    if (w.alive && w.profession == prof) {
                        c = c + 1;
                    }
                    i = i + 1;
                }
                return c;
            }

            // Keep enough builders while there is something to build; otherwise send them to the forests.
            private method reassign() returns void {
                mutable int ni = 0;
                while (ni < this.nations.size()) {
                    mutable Nation* n = this.nations.get(ni);
                    if (n.alive) {
                        mutable int want = 0;
                        if (this.hasBlueprint(n)) {
                            want = 4;
                        }
                        mutable int have = this.countJob(n, 4);
                        if (have < want) {
                            this.retrain(n, 4, want - have);
                        } else if (have > want) {
                            this.retrain(n, 1, have - want);
                        }
                    }
                    ni = ni + 1;
                }
            }

            private method retrain(Nation* n, int toJob, int count) returns void {
                mutable int done = 0;
                mutable int i = 0;
                while (i < n.members.size() && done < count) {
                    mutable Worker* w = n.members.get(i);
                    if (w.alive && w.isAdult() && w.profession != toJob && w.carryRes < 0) {
                        w.profession = toJob;
                        w.targetNode = -1;
                        done = done + 1;
                    }
                    i = i + 1;
                }
            }
        }
    }
}
